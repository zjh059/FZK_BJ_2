<UserControl x:Class="FZK.Application.Debug.Views.BTEntityDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FZK.Application.Debug.Views"
             xmlns:vm="clr-namespace:FZK.Application.Debug.ViewModels"
             xmlns:converters="clr-namespace:FZK.Application.UI.Converters;assembly=FZK.Application.UI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance vm:BTEntityDebugViewModel}">

    <Grid Margin="15" DataContext="{Binding}">
        <!-- 整体布局 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="55"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. 标题 + 工具栏 -->
        <Grid Grid.Row="0" Margin="0 0 0 10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{DynamicResource 底板码盖板码绑定管理}" Style="{StaticResource TitleStyle}"/>

            <!-- 功能按钮组 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="{DynamicResource 新增绑定}" Style="{StaticResource Button.Main.ManualButtonStyle}" Width="100" 
                        Command="{Binding AddCommand}"/>
                <Button Content="{DynamicResource 编辑选中}" Style="{StaticResource Button.Main.ManualButtonStyle}" Width="100" 
                        Command="{Binding EditCommand}" IsEnabled="{Binding CanEdit}"/>
                <Button Content="{DynamicResource 删除选中}" Style="{StaticResource Button.Main.DangerButtonStyle}" Width="100"  x:Name="BatchDeleteBtn"
                        Command="{Binding BatchDeleteCommand}" IsEnabled="{Binding CanDelete}"/>
                <Button Content="{DynamicResource 刷新数据}" Style="{StaticResource Button.Main.SuccessButtonStyle}" Width="100" 
                        Command="{Binding RefreshCommand}"/>
            </StackPanel>
        </Grid>

        <!-- 2. 筛选区 -->
        <Grid Grid.Row="1" Margin="0 0 0 10" Background="White" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{DynamicResource 底板码}" Style="{StaticResource LabelStyle}"/>
            <TextBox Grid.Column="1" Style="{StaticResource TextBox.DBEntity.Style}" x:Name="FilterBottomCode" Width="180"
                     Text="{Binding FilterBottomCode, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Column="2" Text="{DynamicResource 盖板码}" Style="{StaticResource LabelStyle}"/>
            <TextBox Grid.Column="3" Style="{StaticResource TextBox.DBEntity.Style}" x:Name="FilterTopCode" Width="180"
                     Text="{Binding FilterTopCode, UpdateSourceTrigger=PropertyChanged}"/>

            <Button Grid.Column="5" Content="{DynamicResource 筛选数据}" Style="{StaticResource Button.Main.ManualButtonStyle}" Width="100" HorizontalAlignment="Left"
                    Command="{Binding FilterCommand}"/>
        </Grid>

        <!-- 3. 数据展示区（DataGrid） -->
        <DataGrid Grid.Row="2" x:Name="BTEntityDataGrid" Style="{StaticResource DataGrid.Main.Style}"
          ItemsSource="{Binding BTEntities}"
          SelectedItem="{Binding SelectedBTEntity, Mode=TwoWay}">
            <DataGrid.Columns>
                <!-- 主键ID列 -->
                <DataGridTextColumn Header="{DynamicResource ID}" Binding="{Binding Id}" Width="60" SortMemberPath="Id"/>
                <!-- 底板码列 -->
                <DataGridTextColumn Header="{DynamicResource 底板码}" Binding="{Binding BottomCode}" Width="200" SortMemberPath="BottomCode"/>
                <!-- 盖板码列 -->
                <DataGridTextColumn Header="{DynamicResource 盖板码}" Binding="{Binding TopCode}" Width="200" SortMemberPath="TopCode"/>
                <!-- 使用次数列 -->
                <DataGridTextColumn Header="{DynamicResource 使用次数}" Binding="{Binding Counts}" Width="100" SortMemberPath="Counts"/>
                <!-- 最后修改时间列 -->
                <DataGridTextColumn Header="{DynamicResource 最后修改时间}" Binding="{Binding UpdateTime,StringFormat=yyyy-MM-dd HH:mm:ss}" Width="200" SortMemberPath="UpdateTime"/>
                <!-- 行内操作列 -->
                <DataGridTemplateColumn Header="{DynamicResource 操作}" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{DynamicResource 编辑}" Style="{StaticResource Button.Main.ManualButtonStyle}" Width="70" 
                                Command="{Binding DataContext.EditItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                CommandParameter="{Binding Id}" Margin="0 0 5 0"/>
                                <Button Content="{DynamicResource 删除}" Style="{StaticResource Button.Main.DangerButtonStyle}" Width="70" 
                                Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                CommandParameter="{Binding Id}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 4. 编辑/新增表单区 -->
        <Border Grid.Row="3" Margin="0 10 0 0" Background="White" 
                BorderBrush="#CED4DA" BorderThickness="1" Padding="15"
                Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVisibleConvert}}" x:Name="EditFormBorder">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 表单标题 -->
                <TextBlock Grid.Row="0" Text="{Binding FormTitle}" Style="{StaticResource TitleStyle}" x:Name="FormTitle"/>

                <!-- 表单内容 -->
                <Grid Grid.Row="1" Margin="0 10 0 10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 底板码 -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource 底板码}" Style="{StaticResource LabelStyle}"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource TextBox.DBEntity.Style}" x:Name="TxtBottomCode" Width="280"
                             Text="{Binding CurrentEntity.BottomCode, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- 盖板码 -->
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{DynamicResource 盖板码}" Style="{StaticResource LabelStyle}"/>
                    <TextBox Grid.Row="0" Grid.Column="3" Style="{StaticResource TextBox.DBEntity.Style}" x:Name="TxtTopCode" Width="280"
                             Text="{Binding CurrentEntity.TopCode, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- 使用次数 -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource 使用次数}" Style="{StaticResource LabelStyle}"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource TextBox.DBEntity.Style}" x:Name="TxtCounts" Width="280"
                             Text="{Binding CurrentEntity.Counts, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- 最后修改时间（只读） -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource 修改时间}" Style="{StaticResource LabelStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtUpdateTime" 
                               Text="{Binding CurrentEntity.UpdateTime, StringFormat=yyyy-MM-dd HH:mm:ss}"
                               VerticalAlignment="Center" Foreground="#6C757D"/>
                </Grid>

                <!-- 表单操作按钮 -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{DynamicResource 保存}" Style="{StaticResource Button.Main.SuccessButtonStyle}" Width="100" 
                            Command="{Binding SaveCommand}"/>
                    <Button Content="{DynamicResource 取消}" Style="{StaticResource Button.Main.ManualButtonStyle}" Width="100" Margin="10 0 0 0" 
                            Command="{Binding CancelCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>