<UserControl x:Class="FZK.Application.Debug.Views.DataBaseDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FZK.Application.Debug.Views"
             xmlns:prism="http://prismlibrary.com/"             
			 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks" 
			 prism:ViewModelLocator.AutoWireViewModel="True"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:vm="clr-namespace:FZK.Application.Debug.ViewModels"
             xmlns:core="clr-namespace:FZK.Core.Models;assembly=FZK.Core"
             
             d:DataContext="{d:DesignInstance vm:DataBaseDebugViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadedCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <StackPanel Background="White">
            <RadioButton Content="{DynamicResource 底板绑定}"
                         Command="{Binding NavigatonToViewCommand}"
                         Style="{StaticResource RadioButton.Menu.Config.Style}"
                         CommandParameter="{x:Static core:Names.BTEntityDebugView}">
                <RadioButton.Tag>
                    <iconPacks:PackIconMaterialDesign Kind="KeyboardArrowRight" Width="20" Height="20"/>
                </RadioButton.Tag>
            </RadioButton>
            <RadioButton Content="{DynamicResource 主板绑定}"
                         Command="{Binding NavigatonToViewCommand}"
                         CommandParameter="{x:Static core:Names.CodeEntityDebugView}"
                         Style="{StaticResource RadioButton.Menu.Config.Style}"
                         >
                <RadioButton.Tag>
                    <iconPacks:PackIconMaterialDesign Kind="KeyboardArrowRight" Width="20" Height="20"/>
                </RadioButton.Tag>
            </RadioButton>
            <RadioButton Content="{DynamicResource 用户管理}"
               Command="{Binding NavigatonToViewCommand}"
               CommandParameter="{x:Static core:Names.UserEntityDebugView}"
               Style="{StaticResource RadioButton.Menu.Config.Style}"
               >
                <RadioButton.Tag>
                    <iconPacks:PackIconMaterialDesign Kind="KeyboardArrowRight" Width="20" Height="20"/>
                </RadioButton.Tag>
            </RadioButton>

        </StackPanel>
        <ContentControl Grid.Column="1" prism:RegionManager.RegionName="{x:Static core:Names.DBRegion}"/>
    </Grid>
</UserControl>