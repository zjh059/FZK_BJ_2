<UserControl x:Class="FZK.Application.Debug.Views.CodeEntityDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FZK.Application.Debug.Views"
             xmlns:vm="clr-namespace:FZK.Application.Debug.ViewModels"
             xmlns:converters="clr-namespace:FZK.Application.UI.Converters;assembly=FZK.Application.UI"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance vm:CodeEntityDebugViewModel}">

        <Grid Margin="15" DataContext="{Binding}">
            <!-- 整体布局 -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. 标题 + 工具栏（移除Padding，改用Margin） -->
            <Grid Grid.Row="0" Margin="0 0 0 10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{DynamicResource 码值绑定管理_底板_盖板_主板}" Style="{StaticResource TitleStyle}"/>

                <!-- 功能按钮组（绑定命令，移除Padding） -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="{DynamicResource 新增绑定}" Style="{StaticResource Button.Main.ManualButtonStyle}" 
                        Command="{Binding AddCommand}" Margin="0 0 8 0"/>
                    <Button Content="{DynamicResource 编辑选中}" Style="{StaticResource Button.Main.ManualButtonStyle}" x:Name="EditBtn"
                        Command="{Binding EditCommand}" IsEnabled="{Binding CanEdit}" Margin="0 0 8 0"/>
                    <Button Content="{DynamicResource 批量删除}" Style="{StaticResource Button.Main.DangerButtonStyle}" x:Name="BatchDeleteBtn"
                        Command="{Binding BatchDeleteCommand}" IsEnabled="{Binding CanDelete}" Margin="0 0 8 0"/>
                    <Button Content="{DynamicResource 刷新数据}" Style="{StaticResource Button.Main.SuccessButtonStyle}" 
                        Command="{Binding RefreshCommand}" Margin="0 0 8 0"/>
                    <Button Content="{DynamicResource 导出Excel}" Style="{StaticResource Button.Main.ManualButtonStyle}" 
                        Command="{Binding ExportExcelCommand}" Margin="0 0 8 0"/>
                    <Button Content="{DynamicResource 导出CSV}" Style="{StaticResource Button.Main.ManualButtonStyle}"
                        Command="{Binding ExportCsvCommand}" Margin="0 0 8 0"/>
                </StackPanel>
            </Grid>

            <!-- 2. 筛选区（移除Padding，改用Margin+Height） -->
            <Grid Grid.Row="1" Margin="0 0 0 10" Background="White">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{DynamicResource 底板码}" Style="{StaticResource LabelStyle}" Margin="0 5 0 5"/>
                <TextBox Grid.Column="1" Style="{StaticResource TextBox.DBEntity.Style}" x:Name="FilterBottomCode" Width="180"
                     Text="{Binding FilterBottomCode, UpdateSourceTrigger=PropertyChanged}" Margin="0 5 0 5"/>

                <TextBlock Grid.Column="2" Text="{DynamicResource 盖板码}" Style="{StaticResource LabelStyle}" Margin="0 5 0 5"/>
                <TextBox Grid.Column="3" Style="{StaticResource TextBox.DBEntity.Style}" x:Name="FilterTopCode" Width="180"
                     Text="{Binding FilterTopCode, UpdateSourceTrigger=PropertyChanged}" Margin="0 5 0 5"/>

                <TextBlock Grid.Column="4" Text="{DynamicResource 主板码}" Style="{StaticResource LabelStyle}" Margin="0 5 0 5"/>
                <TextBox Grid.Column="5" Style="{StaticResource TextBox.DBEntity.Style}" x:Name="FilterSPCode" Width="180"
                     Text="{Binding FilterSPCode, UpdateSourceTrigger=PropertyChanged}" Margin="0 5 0 5"/>

                <Button Grid.Column="6" Content="{DynamicResource 筛选数据}" Style="{StaticResource Button.Main.ManualButtonStyle}" 
                    Command="{Binding FilterCommand}" HorizontalAlignment="Left" Margin="0 5 0 5"/>
            </Grid>

            <!-- 3. 数据展示区（DataGrid，修复测试结果触发器冲突） -->
            <DataGrid Grid.Row="2" x:Name="CodeEntityDataGrid" Style="{StaticResource DataGridStyle}"
                  ItemsSource="{Binding CodeEntities}"
                  SelectedItem="{Binding SelectedCodeEntity, Mode=TwoWay}"
                  ColumnHeaderStyle="{StaticResource DataGrid.Main.DataGridColumnHeaderStyle}">
                <DataGrid.Columns>
                    <!-- 主键ID列 -->
                    <DataGridTextColumn Header="{DynamicResource ID}" Binding="{Binding Id}" Width="60" SortMemberPath="Id"/>
                    <!-- 底板码列 -->
                    <DataGridTextColumn Header="{DynamicResource 底板码}" Binding="{Binding BottomCode}" Width="180" SortMemberPath="BottomCode"/>
                    <!-- 盖板码列 -->
                    <DataGridTextColumn Header="{DynamicResource 盖板码}" Binding="{Binding TopCode}" Width="180" SortMemberPath="TopCode"/>
                    <!-- 主板码列 -->
                    <DataGridTextColumn Header="{DynamicResource 主板码}" Binding="{Binding SPCode}" Width="180" SortMemberPath="SPCode"/>
                    <!-- 测试结果列（修复触发器冲突：使用Tag属性判断） -->
                    <DataGridTemplateColumn Header="{DynamicResource 测试结果}" Width="120" SortMemberPath="Result">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource ResultTextStyle}"
                                       HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <!-- 插入时间列 -->
                    <DataGridTextColumn Header="{DynamicResource 插入时间}" Binding="{Binding InsertDate,StringFormat=yyyy-MM-dd HH:mm:ss}" Width="200" SortMemberPath="InsertDate"/>
                    <!-- 行内操作列（绑定命令） -->
                    <DataGridTemplateColumn Header="{DynamicResource 操作}" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="{DynamicResource 编辑}" Style="{StaticResource Button.Main.ManualButtonStyle}" Width="70" 
                                        Command="{Binding DataContext.EditItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding Id}" Margin="0 0 5 0"/>
                                    <Button Content="{DynamicResource 删除}" Style="{StaticResource Button.Main.DangerButtonStyle}" Width="70" 
                                        Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding Id}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- 4. 编辑/新增表单区（移除Padding，改用Margin） -->
            <Border Grid.Row="3" Margin="0 10 0 0" Background="White" 
                BorderBrush="#CED4DA" BorderThickness="1"
                Visibility="{Binding IsFormVisible, Converter={StaticResource BoolToVisibleConvert}}" x:Name="EditFormBorder">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 表单标题 -->
                    <TextBlock Grid.Row="0" Text="{Binding FormTitle}" Style="{StaticResource TitleStyle}" x:Name="FormTitle"/>

                    <!-- 表单内容 -->
                    <Grid Grid.Row="1" Margin="0 10 0 10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 底板码 -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource 底板码}" Style="{StaticResource LabelStyle}" Margin="0 5 0 5"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource TextBox.DBEntity.Style}" x:Name="TxtBottomCode" Width="280"
                             Text="{Binding CurrentEntity.BottomCode, UpdateSourceTrigger=PropertyChanged}" Margin="0 5 0 5"/>

                        <!-- 盖板码 -->
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{DynamicResource 盖板码}" Style="{StaticResource LabelStyle}" Margin="0 5 0 5"/>
                        <TextBox Grid.Row="0" Grid.Column="3" Style="{StaticResource TextBox.DBEntity.Style}" x:Name="TxtTopCode" Width="280"
                             Text="{Binding CurrentEntity.TopCode, UpdateSourceTrigger=PropertyChanged}" Margin="0 5 0 5"/>

                        <!-- 主板码 -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource 主板码}" Style="{StaticResource LabelStyle}" Margin="0 5 0 5"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource TextBox.DBEntity.Style}" x:Name="TxtSPCode" Width="280"
                             Text="{Binding CurrentEntity.SPCode, UpdateSourceTrigger=PropertyChanged}" Margin="0 5 0 5"/>

                        <!-- 测试结果 -->
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{DynamicResource 测试结果}" Style="{StaticResource LabelStyle}" Margin="0 5 0 5"/>
                        <ComboBox Grid.Row="1" Grid.Column="3" x:Name="CmbResult" Style="{StaticResource ComboBox.DBEntity.Style}" Width="280"
                              SelectedValue="{Binding CurrentEntity.Result, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Tag" Margin="0 5 0 5">
                            <ComboBoxItem Tag="0" Content="{DynamicResource 未测试}"/>
                            <ComboBoxItem Tag="1" Content="{DynamicResource 合格}"/>
                            <ComboBoxItem Tag="2" Content="{DynamicResource 不合格}"/>
                        </ComboBox>

                        <!-- 插入时间（只读） -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource 插入时间}" Style="{StaticResource LabelStyle}" Margin="0 5 0 5"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TxtInsertDate" 
                               Text="{Binding CurrentEntity.InsertDate, StringFormat=yyyy-MM-dd HH:mm:ss}"
                               VerticalAlignment="Center" Foreground="#6C757D" Margin="0 5 0 5"/>
                    </Grid>

                    <!-- 表单操作按钮（绑定命令） -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 10 0 10">
                        <Button Content="{DynamicResource 保存}" Style="{StaticResource Button.Main.SuccessButtonStyle}" 
                            Command="{Binding SaveCommand}" Margin="0 0 10 0"/>
                        <Button Content="{DynamicResource 取消}" Style="{StaticResource Button.Main.ManualButtonStyle}" 
                            Command="{Binding CancelCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </UserControl>