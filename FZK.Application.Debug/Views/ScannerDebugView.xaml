<UserControl x:Class="FZK.Application.Debug.Views.ScannerDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FZK.Application.Debug.Views"
             mc:Ignorable="d" 
             xmlns:vm="clr-namespace:FZK.Application.Debug.ViewModels"
             d:DataContext="{d:DesignInstance vm:ScannerDebugViewModel}"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="150"/>
        </Grid.ColumnDefinitions>

        <!-- 连接配置区域 -->
        <GroupBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Header="扫码器连接配置" Margin="0 0 0 10">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="IP地址：" VerticalAlignment="Center"/>
                <TextBox x:Name="txtIpAddress" Grid.Column="1" Text="192.168.1.100" Margin="5 0"/>

                <Label Grid.Column="2" Content="端口：" VerticalAlignment="Center"/>
                <TextBox x:Name="txtPort" Grid.Column="3" Text="8080" Margin="5 0"/>

                <Button x:Name="btnConnect" Grid.Column="4" Content="连接" Width="80" 
                        Command="{Binding ConnectScannerCommand}" 
                        Margin="5 0"/>
                <Button x:Name="btnDisconnect" Grid.Column="4" Content="断开" Width="80" 
                        Command="{Binding DisConnectScannerCommand}" 
                        Margin="5 0" 
                        Visibility="Collapsed"/>
            </Grid>
        </GroupBox>

        <!-- 状态显示 -->
        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0 0 0 10">
            <Label Content="连接状态："/>
            <TextBlock x:Name="txtStatus" Text="未连接" Foreground="Red" Margin="5 0 0 0"/>
        </StackPanel>

        <!-- 日志显示区域 -->
        <GroupBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Header="调试日志/扫码数据" Margin="0 0 0 10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBox x:Name="txtLog" Grid.Row="0" IsReadOnly="True" 
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="10"
                         DataContext="{Binding LogText}"
                         />
                <Button Grid.Row="1" Content="清空日志" 
                          Command="{Binding ClearCommand}" 
                        Width="80" HorizontalAlignment="Right" Margin="0 5"/>
            </Grid>
        </GroupBox>

        <!-- 指令发送区域 -->
        <GroupBox Grid.Row="3" Grid.Column="0" Header="发送指令到扫码器" Margin="0 0 10 10">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBox x:Name="txtSendData" Grid.Row="0" 
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                        />
                <Button Grid.Row="1" Content="发送指令" 
                        Command="{Binding SendCommand}" 
                        Width="80" HorizontalAlignment="Right" 
                        Margin="0 5"/>
            </Grid>
        </GroupBox>

        <!-- 扫码数据解析 -->
        <GroupBox Grid.Row="3" Grid.Column="1" Header="解析后的数据" Margin="0 0 0 10">
            <TextBox x:Name="txtParsedData" IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
        </GroupBox>

        <!-- 底部操作 -->
        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 10 0 0">
            <Button Content="自动解析数据" x:Name="btnAutoParse"  
                    Command="{Binding ToggleAutoParseCommand}"  
                    Width="100" Margin="0 0 10 0"/>
        </StackPanel>
    </Grid>
</UserControl>