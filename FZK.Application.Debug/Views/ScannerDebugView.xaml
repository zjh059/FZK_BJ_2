<UserControl x:Class="FZK.Application.Debug.Views.ScannerDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FZK.Application.Debug.Views"
             mc:Ignorable="d" 
             xmlns:vm="clr-namespace:FZK.Application.Debug.ViewModels"
             d:DataContext="{d:DesignInstance vm:ScannerDebugViewModel}"
             d:DesignHeight="900" d:DesignWidth="800">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Page.Background.Color}">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. 连接配置卡片 -->
            <Border Grid.Row="0" Style="{StaticResource Boder.MainStatus.CardStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource 扫码器连接配置}" Style="{StaticResource TextBlock.Run.SubTitleStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource IP地址}" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Column="1" Style="{StaticResource FormTextBoxStyle}" 
                                 Text="{Binding IPAdress, UpdateSourceTrigger=PropertyChanged}"
                                 MinWidth="120"/>

                        <TextBlock Grid.Column="2" Text="{DynamicResource 端口}" Style="{StaticResource FormLabelStyle}" Margin="10,0,0,0"/>
                        <TextBox Grid.Column="3" Style="{StaticResource FormTextBoxStyle}" 
                                 Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                 MinWidth="80"/>

                        <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="{DynamicResource 连接}" Style="{StaticResource Button.Main.SuccessButtonStyle}" 
                                    Command="{Binding ConnectScannerCommand}" 
                                    Visibility="{Binding Connected, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=invert}"/>
                            <Button Content="{DynamicResource 断开}" Style="{StaticResource Button.Main.DangerButtonStyle}" 
                                    Command="{Binding DisconnectScannerCommand}" 
                                    Visibility="{Binding Connected, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 2. 状态显示卡片 -->
            <Border Grid.Row="1" Style="{StaticResource Boder.MainStatus.CardStyle}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource 连接状态}" Style="{StaticResource FormLabelStyle}" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding StatusText}" Style="{StaticResource StatusTextStyle}"
                               Foreground="{Binding Connected, Converter={StaticResource BoolToColorConverter}}"/>
                </StackPanel>
            </Border>

            <!-- 3. 调试日志/扫码数据卡片 -->
            <Border Grid.Row="2" Style="{StaticResource Boder.MainStatus.CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="{DynamicResource 调试日志扫码数据}" Style="{StaticResource TextBlock.Run.SubTitleStyle}" Margin="0,0,0,12"/>
                    <TextBox Grid.Row="1" Style="{StaticResource ReadOnlyTextBoxStyle}" 
                             Text="{Binding LogText}" Height="200"/>
                    <Button Grid.Row="2" Content="{DynamicResource 清空日志}" Style="{StaticResource PrimaryButtonStyle}" 
                            Command="{Binding ClearLogCommand}"   HorizontalAlignment="Right" Margin="0,10,0,0"/>
                </Grid>
            </Border>

            <!-- 4. 指令发送与数据解析区域（两列布局） -->
            <Grid Grid.Row="3" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：发送指令卡片 -->
                <Border Grid.Column="0" Style="{StaticResource Boder.MainStatus.CardStyle}" Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="{DynamicResource 发送指令到扫码器}" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,12"/>
                        <TextBox Grid.Row="1" Style="{StaticResource FormTextBoxStyle}" 
                                 Text="{Binding SendData, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="80" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                        <Button Grid.Row="2" Content="{DynamicResource 发送指令}" Style="{StaticResource Button.Main.ManualButtonStyle}" 
                                Command="{Binding SendDataCommand}"   HorizontalAlignment="Right" Margin="0,10,0,0"/>
                    </Grid>
                </Border>

                <!-- 右侧：解析后的数据卡片 -->
                <Border Grid.Column="1" Style="{StaticResource Boder.MainStatus.CardStyle}" Margin="10,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="{DynamicResource 解析后的数据}" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,12"/>
                        <TextBox Grid.Row="1" Style="{StaticResource ReadOnlyTextBoxStyle}" 
                                 Text="{Binding ParsedData}"
                                 Height="Auto"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- 5. 底部操作按钮卡片 -->
            <Border Grid.Row="4" Style="{StaticResource Boder.MainStatus.CardStyle}" Margin="0,0,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{DynamicResource 自动解析数据}" Style="{StaticResource PrimaryButtonStyle}" 
                            Command="{Binding ToggleAutoParseCommand}" Width="120"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>