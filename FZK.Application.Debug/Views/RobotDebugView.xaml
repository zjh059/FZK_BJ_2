<UserControl x:Class="FZK.Application.Debug.Views.RobotDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FZK.Application.Debug.Views"
             xmlns:vm="clr-namespace:FZK.Application.Debug.ViewModels"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:converters="clr-namespace:FZK.Application.UI.Converters;assembly=FZK.Application.UI"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             d:DataContext="{d:DesignInstance vm:RobotDebugViewModel}"
             Background="#F9FAFB">



    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Page.Background.Color}">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. 模式选择与标题卡片 -->
            <Border Grid.Row="0" Style="{StaticResource Boder.MainStatus.CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource 网络调试工具}" 
                               FontSize="20" FontWeight="Bold" Foreground="#1A202C"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <RadioButton Content="{DynamicResource 服务器模式}" IsChecked="{Binding IsServerMode}" Margin="5,0"/>
                        <RadioButton Content="{DynamicResource 客户端模式}" IsChecked="{Binding IsClientMode}" Margin="5,0"/>
                        <TextBlock Text="{DynamicResource 协议}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        <ComboBox Width="80" SelectedItem="{Binding SelectedProtocol}"
                                  Style="{StaticResource FormComboBoxStyle}" Margin="5,0">
                            <ComboBoxItem Content="{DynamicResource TCP}"/>
                            <ComboBoxItem Content="{DynamicResource UDP}"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 2. 连接配置卡片 -->
            <Border Grid.Row="1" Style="{StaticResource Boder.MainStatus.CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 服务器模式 -->
                    <TextBlock Grid.Column="0" Text="{DynamicResource 监听IP}" Style="{StaticResource FormLabelStyle}"
                               Visibility="{Binding IsServerMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <TextBox Grid.Column="1" Style="{StaticResource FormTextBoxStyle}" 
                             Text="{Binding ListenIp}" MinWidth="120"
                             Visibility="{Binding IsServerMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <!-- 客户端模式 -->
                    <TextBlock Grid.Column="0" Text="{DynamicResource 目标IP}" Style="{StaticResource FormLabelStyle}"
                               Visibility="{Binding IsClientMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <TextBox Grid.Column="1" Style="{StaticResource FormTextBoxStyle}" 
                             Text="{Binding TargetIp}" MinWidth="120"
                             Visibility="{Binding IsClientMode, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <TextBlock Grid.Column="2" Text="{DynamicResource 端口}" Style="{StaticResource FormLabelStyle}" Margin="10,0,0,0"/>
                    <TextBox Grid.Column="3" Style="{StaticResource FormTextBoxStyle}" 
                             Text="{Binding Port}" MinWidth="80"/>

                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                        <Ellipse Width="14" Height="14" Fill="{Binding ConnectionStatusColor}" Stroke="#E1E4E8" StrokeThickness="1"/>
                        <TextBlock Text="{Binding ConnectionStatusText}" FontWeight="Medium" Margin="5,0,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="5" Content="{Binding StartButtonText}" Style="{StaticResource Button.Main.ManualButtonStyle}"
                            Command="{Binding StartCommand}" IsEnabled="{Binding CanStart}" Margin="10,0,5,0"/>
                    <Button Grid.Column="6" Content="{Binding StopButtonText}" Style="{StaticResource Button.Main.DangerButtonStyle}"
                            Command="{Binding StopCommand}" IsEnabled="{Binding CanStop}"/>
                </Grid>
            </Border>

            <!-- 3. 主体内容区（两列） -->
            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：客户端列表卡片 -->
                <Border Grid.Column="0" Style="{StaticResource Boder.MainStatus.CardStyle}" Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{DynamicResource 客户端连接列表}" Style="{StaticResource TextBlock.Run.SubTitleStyle}" Margin="0,0,0,0"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="{Binding ClientCountText}" VerticalAlignment="Center"/>
                                <Button Content="{DynamicResource 清空列表}" Style="{StaticResource Button.Main.ManualButtonStyle}"  
                                        Command="{Binding ClearClientListCommand}" Margin="10,0,0,0"/>
                            </StackPanel>
                        </Grid>
                        <ListBox Grid.Row="1" ItemsSource="{Binding ConnectedClients}"
                                 Style="{StaticResource ListBoxStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="{DynamicResource 断开}" Width="70"
                                                Style="{StaticResource Button.Main.DangerButtonStyle}"
                                                Command="{Binding DataContext.DisconnectClientCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- 右侧：发送区卡片 -->
                <Border Grid.Column="1" Style="{StaticResource Boder.MainStatus.CardStyle}" Margin="10,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 发送选项 -->
                        <WrapPanel Grid.Row="0" Margin="0,0,0,12">
                            <CheckBox Content="{DynamicResource 十六进制发送}" IsChecked="{Binding IsHexSend}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                            <CheckBox Content="{DynamicResource 自动换行}" IsChecked="{Binding IsAutoNewLine}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                            <CheckBox Content="{DynamicResource 发送后清空}" IsChecked="{Binding IsClearAfterSend}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                            <TextBlock Text="{DynamicResource 编码}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <ComboBox Width="80" SelectedItem="{Binding SelectedEncoding}"
                                      Style="{StaticResource FormComboBoxStyle}">
                                <ComboBoxItem Content="{DynamicResource UTF8}"/>
                                <ComboBoxItem Content="{DynamicResource GB2312}"/>
                                <ComboBoxItem Content="{DynamicResource ASCII}"/>
                            </ComboBox>
                        </WrapPanel>

                        <!-- 发送数据文本框 -->
                        <TextBox Grid.Row="1" Style="{StaticResource MultiLineTextBoxStyle}"
                                 Text="{Binding SendData}" Margin="0,0,0,12"/>

                        <!-- 快捷指令 -->
                        <Grid Grid.Row="2" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" ItemsSource="{Binding QuickCommands}"
                                      SelectedItem="{Binding SelectedQuickCommand}"
                                      Style="{StaticResource FormComboBoxStyle}"
                                      />
                            <Button Grid.Column="1" Content="{DynamicResource 加载指令库}" Style="{StaticResource Button.Main.SuccessButtonStyle}" Width="120"
                                    Command="{Binding LoadCommandLibraryCommand}" Margin="5,0,0,0"/>
                        </Grid>

                        <!-- 发送按钮 -->
                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="{DynamicResource 发送}" Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding SendDataCommand}" IsEnabled="{Binding CanSend}"/>
                            <Button Content="{Binding TimedSendButtonText}" Style="{StaticResource WarningButtonStyle}"
                                    Command="{Binding ToggleTimedSendCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- 4. 日志/数据接收区卡片 -->
            <Border Grid.Row="3" Style="{StaticResource Boder.MainStatus.CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 日志控制栏 -->
                    <WrapPanel Grid.Row="0" Margin="0,0,0,12">
                        <CheckBox Content="{DynamicResource 显示时间戳}" IsChecked="{Binding ShowTimestamp}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <CheckBox Content="{DynamicResource 显示收发标识}" IsChecked="{Binding ShowSendRecvFlag}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <CheckBox Content="{DynamicResource 十六进制显示}" IsChecked="{Binding IsHexDisplay}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <TextBlock Text="{Binding ByteCountText}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <Button Content="{DynamicResource 清空日志}" Style="{StaticResource Button.Main.ManualButtonStyle}"  
                                Command="{Binding ClearLogCommand}" Margin="0,0,5,0"/>
                        <Button Content="{DynamicResource 保存日志}" Style="{StaticResource Button.Main.ManualButtonStyle}"   
                                Command="{Binding SaveLogCommand}"/>
                    </WrapPanel>

                    <!-- 日志文本框 -->
                    <TextBox Grid.Row="1" Style="{StaticResource LogTextBoxStyle}" Text="{Binding LogText}"
                             Height="200" Margin="0,0,0,12"/>

                    <!-- 底部统计与导入导出 -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding StatisticsText}" 
                                   FontSize="11" Foreground="#6C757D" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="{DynamicResource 导出配置}" Style="{StaticResource Button.Main.ManualButtonStyle}"
                                    Command="{Binding ExportConfigCommand}" FontSize="11" Height="28" Padding="8,4"/>
                            <Button Content="{DynamicResource 导入配置}" Style="{StaticResource Button.Main.ManualButtonStyle}"
                                    Command="{Binding ImportConfigCommand}" FontSize="11" Height="28" Padding="8,4"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>