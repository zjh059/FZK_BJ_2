<UserControl x:Class="FZK.Application.Debug.Views.RobotDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FZK.Application.Debug.Views"
             xmlns:vm="clr-namespace:FZK.Application.Debug.ViewModels"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:converters="clr-namespace:FZK.Application.UI.Converters;assembly=FZK.Application.UI"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:RobotDebugViewModel}"
             Background="#F5F5F5">

    <!-- 资源定义 -->
    <UserControl.Resources>
        <!-- 引用你提供的布尔转可见性转换器 -->
        <converters:BoolToVisibleConvert x:Key="BooleanToVisibilityConverter"/>

        <!-- 通用按钮样式（移除CornerRadius） -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#007BFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8 4"/>
            <Setter Property="FontSize" Value="12"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#6C757D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#DC3545"/>
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#28A745"/>
        </Style>

        <Style x:Key="WarningButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFC107"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#6C757D"/>
        </Style>

        <!-- 文本框样式（移除CornerRadius） -->
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#E1E4E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- 列表框样式 -->
        <Style x:Key="ListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E1E4E8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="2"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10" DataContext="{Binding}">
        <!-- 整体布局 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. 模式选择与标题 -->
        <Grid Grid.Row="0" Margin="0 0 0 15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="网络调试工具 (TCP/UDP)" 
                       FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <RadioButton Content="服务器模式" 
                             IsChecked="{Binding IsServerMode}" 
                             VerticalAlignment="Center"/>
                <RadioButton Content="客户端模式" 
                             IsChecked="{Binding IsClientMode}" 
                             VerticalAlignment="Center"/>
                <TextBlock Text="协议：" VerticalAlignment="Center"/>
                <ComboBox Width="80" VerticalAlignment="Center"
                          SelectedItem="{Binding SelectedProtocol}">
                    <ComboBoxItem Content="TCP"/>
                    <ComboBoxItem Content="UDP"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- 2. 连接配置区（移除CornerRadius，改用Border无圆角） -->
        <Border Grid.Row="1" Margin="0 0 0 15" Background="White" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <!-- 服务器配置 -->
                <TextBlock Grid.Column="0" Text="监听IP：" VerticalAlignment="Center"
                           Visibility="{Binding IsServerMode, Converter={StaticResource BoolToVisibleConvert}}"/>
                <TextBox Grid.Column="1" Text="{Binding ListenIp}" Margin="5 0" 
                         Style="{StaticResource InputTextBoxStyle}"
                         Visibility="{Binding IsServerMode, Converter={StaticResource BoolToVisibleConvert}}"/>

                <!-- 客户端配置 -->
                <TextBlock Grid.Column="0" Text="目标IP：" VerticalAlignment="Center"
                           Visibility="{Binding IsClientMode, Converter={StaticResource BoolToVisibleConvert}}"/>
                <TextBox Grid.Column="1" Text="{Binding TargetIp}" Margin="5 0" 
                         Style="{StaticResource InputTextBoxStyle}"
                         Visibility="{Binding IsClientMode, Converter={StaticResource BoolToVisibleConvert}}"/>

                <TextBlock Grid.Column="2" Text="端口：" VerticalAlignment="Center"/>
                <TextBox Grid.Column="3" Text="{Binding Port}" Margin="5 0" 
                         Style="{StaticResource InputTextBoxStyle}"/>

                <!-- 状态显示 -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="14" Height="14" 
                             Fill="{Binding ConnectionStatusColor}" 
                             Stroke="#E1E4E8" StrokeThickness="1"/>
                    <TextBlock Text="{Binding ConnectionStatusText}" FontWeight="Medium"/>
                </StackPanel>

                <!-- 控制按钮 -->
                <Button Grid.Column="6" Content="{Binding StartButtonText}" Width="90" Margin="0 0 8 0"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding StartCommand}"
                        IsEnabled="{Binding CanStart}"/>
                <Button Grid.Column="7" Content="{Binding StopButtonText}" Width="90"
                        Style="{StaticResource DangerButtonStyle}"
                        Command="{Binding StopCommand}"
                        IsEnabled="{Binding CanStop}"/>
            </Grid>
        </Border>

        <!-- 3. 主体内容区 -->
        <Grid Grid.Row="2" Margin="0 0 0 15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：客户端列表 -->
            <Grid Grid.Column="0" Margin="0 0 10 0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="客户端连接列表 (服务器模式)" Margin="0 0 0 10">
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <TextBlock Text="{Binding ClientCountText}" VerticalAlignment="Center"/>
                        <Button Content="清空列表" Width="80"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ClearClientListCommand}"/>
                    </StackPanel>
                </GroupBox>

                <ListBox Grid.Row="1" 
                         ItemsSource="{Binding ConnectedClients}"
                         Style="{StaticResource ListBoxStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="断开" Width="70" Margin="5 0 0 0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding DataContext.DisconnectClientCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <!-- 右侧：发送区 -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="发送数据" Margin="0 0 0 10">
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <CheckBox Content="十六进制发送" IsChecked="{Binding IsHexSend}" VerticalAlignment="Center"/>
                        <CheckBox Content="自动换行" IsChecked="{Binding IsAutoNewLine}" VerticalAlignment="Center"/>
                        <CheckBox Content="发送后清空" IsChecked="{Binding IsClearAfterSend}" VerticalAlignment="Center"/>
                        <TextBlock Text="编码：" VerticalAlignment="Center"/>
                        <ComboBox Width="80" VerticalAlignment="Center"
                                  SelectedItem="{Binding SelectedEncoding}">
                            <ComboBoxItem Content="UTF-8"/>
                            <ComboBoxItem Content="GB2312"/>
                            <ComboBoxItem Content="ASCII"/>
                        </ComboBox>
                    </StackPanel>
                </GroupBox>

                <TextBox Grid.Row="1" 
                         Text="{Binding SendData}"
                         VerticalScrollBarVisibility="Auto" 
                         HorizontalScrollBarVisibility="Auto"
                         AcceptsReturn="True"
                         Style="{StaticResource InputTextBoxStyle}"
                         Margin="0 0 0 10"/>

                <Grid Grid.Row="2" Margin="0 0 0 10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0" 
                              ItemsSource="{Binding QuickCommands}"
                              SelectedItem="{Binding SelectedQuickCommand}"/>

                    <Button Grid.Column="1" Content="加载指令库" Width="110"
                            Style="{StaticResource SuccessButtonStyle}"
                            Command="{Binding LoadCommandLibraryCommand}"/>
                </Grid>

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="发送" Width="90"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding SendDataCommand}"
                            IsEnabled="{Binding CanSend}"/>
                    <Button Content="{Binding TimedSendButtonText}" Width="90"
                            Style="{StaticResource WarningButtonStyle}"
                            Command="{Binding ToggleTimedSendCommand}"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- 4. 日志/数据接收区 -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0" Header="数据收发日志" Margin="0 0 0 10">
                <StackPanel Orientation="Horizontal" Margin="5">
                    <CheckBox Content="显示时间戳" IsChecked="{Binding ShowTimestamp}" VerticalAlignment="Center"/>
                    <CheckBox Content="显示收发标识" IsChecked="{Binding ShowSendRecvFlag}" VerticalAlignment="Center"/>
                    <CheckBox Content="十六进制显示" IsChecked="{Binding IsHexDisplay}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ByteCountText}" VerticalAlignment="Center"/>
                    <Button Content="清空日志" Width="80"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding ClearLogCommand}"/>
                    <Button Content="保存日志" Width="80"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding SaveLogCommand}"/>
                </StackPanel>
            </GroupBox>

            <TextBox Grid.Row="1" 
                     Text="{Binding LogText}"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     FontSize="10"
                     Style="{StaticResource InputTextBoxStyle}"
                     AcceptsReturn="True"/>

            <Grid Grid.Row="2" Margin="0 10 0 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatisticsText}" 
                           FontSize="10" Foreground="#6C757D"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="导出配置" Width="90"
                            Style="{StaticResource SecondaryButtonStyle}"
                            FontSize="10"
                            Command="{Binding ExportConfigCommand}"/>
                    <Button Content="导入配置" Width="90"
                            Style="{StaticResource SecondaryButtonStyle}"
                            FontSize="10"
                            Command="{Binding ImportConfigCommand}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>