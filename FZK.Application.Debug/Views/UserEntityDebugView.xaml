<UserControl x:Class="FZK.Application.Debug.Views.UserEntityDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FZK.Application.Debug.Views"
             xmlns:vm="clr-namespace:FZK.Application.Debug.ViewModels"
             xmlns:converters="clr-namespace:FZK.Application.UI.Converters;assembly=FZK.Application.UI"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance vm:UserEntityDebugViewModel}">
    <!-- 统一样式定义（适配WPF 4.7.2，无兼容性报错） -->
    <UserControl.Resources>
        <!-- 布尔转可见性转换器 -->
        <converters:BoolToVisibleConvert x:Key="BooleanToVisibilityConverter"/>
        <converters:PasswordMaskConverter x:Key="PasswordMaskConverter"/>

        <!-- 标题样式 -->
        <Style x:Key="TitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0 0 0 15"/>
            <Setter Property="Foreground" Value="#212529"/>
        </Style>

        <!-- 按钮样式（禁用态+统一尺寸） -->
        <Style x:Key="ButtonPrimaryStyle" TargetType="Button">
            <Setter Property="Background" Value="#007BFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0 0 8 0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="100"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#6C757D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ButtonDangerStyle" TargetType="Button">
            <Setter Property="Background" Value="#DC3545"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0 0 8 0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="100"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#6C757D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ButtonSuccessStyle" TargetType="Button">
            <Setter Property="Background" Value="#28A745"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0 0 8 0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="100"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#6C757D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 输入框样式（兼容4.7.2） -->
        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="Margin" Value="0 0 8 0"/>
            <Setter Property="BorderBrush" Value="#CED4DA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- 下拉框样式（角色选择） -->
        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Margin" Value="0 0 8 0"/>
            <Setter Property="BorderBrush" Value="#CED4DA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- 数据表格样式 -->
        <Style x:Key="DataGridStyle" TargetType="DataGrid">
            <Setter Property="AlternatingRowBackground" Value="#F8F9FA"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="BorderBrush" Value="#CED4DA"/>
            <Setter Property="RowHeight" Value="35"/>
            <Setter Property="Margin" Value="0 10 0 0"/>
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
        </Style>

        <!-- 表头样式 -->
        <Style x:Key="DataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E9ECEF"/>
            <Setter Property="Foreground" Value="#212529"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0 0 1 1"/>
            <Setter Property="BorderBrush" Value="#CED4DA"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- 标签样式 -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0 0 5 0"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="TextAlignment" Value="Right"/>
        </Style>

        <!-- 角色文本样式（区分不同角色） -->
        <Style x:Key="RoleTextStyle" TargetType="TextBlock">
            <Setter Property="Tag" Value="{Binding Role}"/>
            <Style.Triggers>
                <Trigger Property="Tag" Value="0">
                    <Setter Property="Foreground" Value="#6C757D"/>
                    <Setter Property="Text" Value="{DynamicResource 普通用户}"/>
                </Trigger>
                <Trigger Property="Tag" Value="1">
                    <Setter Property="Foreground" Value="#28A745"/>
                    <Setter Property="Text" Value="{DynamicResource 管理员}"/>
                </Trigger>
                <Trigger Property="Tag" Value="2">
                    <Setter Property="Foreground" Value="#007BFF"/>
                    <Setter Property="Text" Value="{DynamicResource 超级管理员}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="15" DataContext="{Binding}">
        <!-- 整体布局 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. 标题 + 工具栏 -->
        <Grid Grid.Row="0" Margin="0 0 0 10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{DynamicResource 用户管理}" Style="{StaticResource TitleStyle}"/>

            <!-- 功能按钮组 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="{DynamicResource 新增用户}" Style="{StaticResource ButtonPrimaryStyle}" 
                        Command="{Binding AddCommand}" Margin="0 0 8 0"/>
                <Button Content="{DynamicResource 编辑选中}" Style="{StaticResource ButtonPrimaryStyle}" x:Name="EditBtn"
                        Command="{Binding EditCommand}" IsEnabled="{Binding CanEdit}" Margin="0 0 8 0"/>
                <Button Content="{DynamicResource 批量删除}" Style="{StaticResource ButtonDangerStyle}" x:Name="BatchDeleteBtn"
                        Command="{Binding BatchDeleteCommand}" IsEnabled="{Binding CanDelete}" Margin="0 0 8 0"/>
                <Button Content="{DynamicResource 刷新数据}" Style="{StaticResource ButtonSuccessStyle}" 
                        Command="{Binding RefreshCommand}" Margin="0 0 8 0"/>
            </StackPanel>
        </Grid>

        <!-- 2. 筛选区 -->
        <Grid Grid.Row="1" Margin="0 0 0 10" Background="White">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{DynamicResource 用户名}" Style="{StaticResource LabelStyle}" Margin="0 5 0 5"/>
            <TextBox Grid.Column="1" Style="{StaticResource TextBoxStyle}" x:Name="FilterUserName" Width="180"
                     Text="{Binding FilterUserName, UpdateSourceTrigger=PropertyChanged}" Margin="0 5 0 5"/>

            <TextBlock Grid.Column="2" Text="{DynamicResource 角色}" Style="{StaticResource LabelStyle}" Margin="0 5 0 5"/>
            <ComboBox Grid.Column="3" Style="{StaticResource ComboBoxStyle}" x:Name="FilterRole" Width="180"
                      SelectedValue="{Binding FilterRole, UpdateSourceTrigger=PropertyChanged}"
                      SelectedValuePath="Tag" Margin="0 5 0 5">
                <ComboBoxItem Tag="-1" Content="{DynamicResource 全部}"/>
                <ComboBoxItem Tag="0" Content="{DynamicResource 普通用户}"/>
                <ComboBoxItem Tag="1" Content="{DynamicResource 管理员}"/>
                <ComboBoxItem Tag="2" Content="{DynamicResource 超级管理员}"/>
            </ComboBox>

            <Button Grid.Column="4" Content="{DynamicResource 筛选数据}" Style="{StaticResource ButtonPrimaryStyle}" 
                    Command="{Binding FilterCommand}" HorizontalAlignment="Left" Margin="0 5 0 5"/>
        </Grid>

        <!-- 3. 数据展示区（DataGrid） -->
        <DataGrid Grid.Row="2" x:Name="UserEntityDataGrid" Style="{StaticResource DataGridStyle}"
                  ItemsSource="{Binding UserEntities}"
                  SelectedItem="{Binding SelectedUserEntity, Mode=TwoWay}"
                  ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
            <DataGrid.Columns>
                <!-- 主键ID列 -->
                <DataGridTextColumn Header="{DynamicResource ID}" Binding="{Binding Id}" Width="60" SortMemberPath="Id"/>
                <!-- 用户名列 -->
                <DataGridTextColumn Header="{DynamicResource 用户名}" Binding="{Binding UserName}" Width="180" SortMemberPath="UserName"/>
                <!-- 密码列（脱敏显示） -->
                <DataGridTextColumn Header="{DynamicResource 密码}" Binding="{Binding Password, Converter={StaticResource PasswordMaskConverter}}" Width="180" SortMemberPath="Password"/>
                <!-- 角色列 -->
                <DataGridTemplateColumn Header="{DynamicResource 角色}" Width="120" SortMemberPath="Role">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Style="{StaticResource RoleTextStyle}" HorizontalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!-- 行内操作列 -->
                <DataGridTemplateColumn Header="{DynamicResource 操作}" Width="160">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="{DynamicResource 编辑}" Style="{StaticResource ButtonPrimaryStyle}" Width="70" 
                                        Command="{Binding DataContext.EditItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding Id}" Margin="0 0 5 0"/>
                                <Button Content="{DynamicResource 删除}" Style="{StaticResource ButtonDangerStyle}" Width="70" 
                                        Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding Id}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 4. 编辑/新增表单区 -->
        <Border Grid.Row="3" Margin="0 10 0 0" Background="White" 
                BorderBrush="#CED4DA" BorderThickness="1"
                Visibility="{Binding IsFormVisible, Converter={StaticResource BooleanToVisibilityConverter}}" x:Name="EditFormBorder">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 表单标题 -->
                <TextBlock Grid.Row="0" Text="{Binding FormTitle}" Style="{StaticResource TitleStyle}" x:Name="FormTitle"/>

                <!-- 表单内容 -->
                <Grid Grid.Row="1" Margin="0 10 0 10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 用户名 -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource 用户名}" Style="{StaticResource LabelStyle}" Margin="0 5 0 5"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource TextBoxStyle}" x:Name="TxtUserName" Width="280"
                             Text="{Binding CurrentEntity.UserName, UpdateSourceTrigger=PropertyChanged}" Margin="0 5 0 5"/>

                    <!-- 密码 -->
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{DynamicResource 密码}" Style="{StaticResource LabelStyle}" Margin="0 5 0 5"/>
                    <PasswordBox Grid.Row="0" Grid.Column="3" x:Name="PwdPassword" Width="280" Height="32" Margin="0 5 0 5"
             local:PasswordBoxHelper.BindPassword="{Binding CurrentEntity.Password, Mode=TwoWay}"/>

                    <!-- 角色 -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource 角色}" Style="{StaticResource LabelStyle}" Margin="0 5 0 5"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" Style="{StaticResource ComboBoxStyle}" x:Name="CmbRole" Width="280"
                              SelectedValue="{Binding CurrentEntity.Role, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Tag" Margin="0 5 0 5">
                        <ComboBoxItem Tag="0" Content="{DynamicResource 普通用户}"/>
                        <ComboBoxItem Tag="1" Content="{DynamicResource 管理员}"/>
                        <ComboBoxItem Tag="2" Content="{DynamicResource 超级管理员}"/>
                    </ComboBox>
                </Grid>

                <!-- 表单操作按钮 -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 10 0 10">
                    <Button Content="{DynamicResource 保存}" Style="{StaticResource ButtonSuccessStyle}" 
                            Command="{Binding SaveCommand}" Margin="0 0 10 0"/>
                    <Button Content="{DynamicResource 取消}" Style="{StaticResource ButtonPrimaryStyle}" 
                            Command="{Binding CancelCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>