<UserControl x:Class="FZK.Application.Debug.Views.PLCDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FZK.Application.Debug.Views"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             xmlns:prism="http://prismlibrary.com/"             
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks" 
             prism:ViewModelLocator.AutoWireViewModel="True"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:vm="clr-namespace:FZK.Application.Debug.ViewModels"
             d:DataContext="{d:DesignInstance vm:PLCDebugViewModel}">

    <UserControl.Resources>
        <!-- 全局背景 -->
        <SolidColorBrush x:Key="PageBackground" Color="#F9FAFB"/>

        <!-- 卡片样式（无圆角） -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <!-- 卡片标题样式 -->
        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <!-- 按钮样式（统一） -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3182CE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="5,0"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#95A5A6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#27AE60"/>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#E74C3C"/>
        </Style>

        <Style x:Key="InfoButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#1ABC9C"/>
        </Style>

        <!-- 标签样式 -->
        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,5,10,5"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- 文本框样式 -->
        <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
            <Setter Property="Background" Value="#F7FAFC"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#3182CE"/>
                    <Setter Property="Background" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 只读文本框样式 -->
        <Style x:Key="ReadOnlyTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource FormTextBoxStyle}">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>

        <!-- 组合框样式 -->
        <Style x:Key="FormComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E0"/>
            <Setter Property="Background" Value="#F7FAFC"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
        </Style>

        <!-- 日志文本框样式 -->
        <Style x:Key="LogTextBoxStyle" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Height" Value="200"/>
        </Style>

        <!-- 状态圆点 -->
        <Style x:Key="StatusDotStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="15"/>
            <Setter Property="Height" Value="15"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource PageBackground}">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. 连接配置卡片 -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="连接配置" Style="{StaticResource CardTitleStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="IP地址" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Column="1" Style="{StaticResource FormTextBoxStyle}" Text="{Binding IPAdress}" Width="120"/>

                        <TextBlock Grid.Column="2" Text="网络号" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Column="3" Style="{StaticResource FormTextBoxStyle}" Text="{Binding NetworkNo}" Width="60"/>

                        <TextBlock Grid.Column="4" Text="节点号" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Column="5" Style="{StaticResource FormTextBoxStyle}" Text="{Binding NodeNo}" Width="60"/>

                        <TextBlock Grid.Column="6" Text="端口" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Column="7" Style="{StaticResource FormTextBoxStyle}" Text="{Binding Port}" Width="80"/>

                        <StackPanel Grid.Column="8" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="连接" Style="{StaticResource SuccessButtonStyle}" Command="{Binding ConnectPlcCommand}" Margin="5"/>
                            <Button Content="断开" Style="{StaticResource DangerButtonStyle}" Command="{Binding DisconnectPlcCommand}" 
                                    IsEnabled="{Binding Connected}" Margin="5"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 2. 设备状态卡片 -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="设备状态" Style="{StaticResource CardTitleStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="连接状态：" Style="{StaticResource FormLabelStyle}"/>
                        <Ellipse Grid.Column="1" Style="{StaticResource StatusDotStyle}" Fill="{Binding Connected, Converter={StaticResource BoolToColorConverter}}"/>

                        <TextBlock Grid.Column="2" Text="心跳值(DM9999)：" Style="{StaticResource FormLabelStyle}" Margin="20,0,0,0"/>
                        <TextBlock Grid.Column="3" Text="{Binding HeartbeatValue}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>

                        <Ellipse Grid.Column="4" Style="{StaticResource StatusDotStyle}" Fill="{Binding HeartbeatStateColor}" Margin="20,0,5,0"/>
                        <TextBlock Grid.Column="5" Text="{Binding HeartbeatStateText}" FontSize="12" Foreground="Gray" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 3. 地址监听卡片 -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="地址监听" Style="{StaticResource CardTitleStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="地址类型" Style="{StaticResource FormLabelStyle}"/>
                        <ComboBox Grid.Column="1" Style="{StaticResource FormComboBoxStyle}" Width="100" 
                                  ItemsSource="{Binding MonitorAddressTypes}" SelectedItem="{Binding MonitorAddressType}"/>

                        <TextBlock Grid.Column="2" Text="地址" Style="{StaticResource FormLabelStyle}" Margin="10,0,0,0"/>
                        <TextBox Grid.Column="3" Style="{StaticResource FormTextBoxStyle}" Width="100" Text="{Binding MonitorAddress}"/>

                        <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="10,0,0,0">
                            <Button Content="开始监听" Style="{StaticResource InfoButtonStyle}" Command="{Binding StartMonitorCommand}" 
                                    IsEnabled="{Binding IsPlcConnected}" Margin="0,0,5,0"/>
                            <Button Content="停止监听" Style="{StaticResource DangerButtonStyle}" Command="{Binding StopMonitorCommand}" 
                                    IsEnabled="{Binding IsMonitoring}" Margin="5,0,0,0"/>
                        </StackPanel>

                        <TextBlock Grid.Column="5" Text="当前值：" Style="{StaticResource FormLabelStyle}" Margin="20,0,0,0"/>
                        <TextBlock Grid.Column="6" Text="{Binding MonitorValue}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="7" Text="{Binding MonitorTips}" FontSize="12" Foreground="Blue" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 4. 单地址读写卡片 -->
            <Border Grid.Row="3" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="单地址读写" Style="{StaticResource CardTitleStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="地址类型" Style="{StaticResource FormLabelStyle}"/>
                        <ComboBox Grid.Column="1" Style="{StaticResource FormComboBoxStyle}" Width="100" 
                                  ItemsSource="{Binding PLCRegisterTypes}" SelectedItem="{Binding RegisterTypes}"/>

                        <TextBlock Grid.Column="2" Text="地址" Style="{StaticResource FormLabelStyle}" Margin="10,0,0,0"/>
                        <TextBox Grid.Column="3" Style="{StaticResource FormTextBoxStyle}" Width="100" Text="{Binding RwAddress, UpdateSourceTrigger=PropertyChanged}"/>

                        <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="10,0,0,0">
                            <Button Content="读取" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ReadCommand}" 
                                    IsEnabled="{Binding IsPlcConnected}" Margin="0,0,5,0"/>
                            <TextBox Grid.Column="5" Style="{StaticResource ReadOnlyTextBoxStyle}" Width="80" Text="{Binding RwReadValue}" Margin="5,0"/>
                        </StackPanel>

                        <TextBlock Grid.Column="6" Text="写入值：" Style="{StaticResource FormLabelStyle}" Margin="20,0,0,0"/>
                        <TextBox Grid.Column="7" Style="{StaticResource FormTextBoxStyle}" Width="80" Text="{Binding RwWriteValue, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                        <Button Grid.Column="8" Content="写入" Style="{StaticResource SuccessButtonStyle}" 
                                Command="{Binding WriteCommand}" IsEnabled="{Binding IsPlcConnected}" Margin="5"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 5. 操作日志卡片 -->
            <Border Grid.Row="4" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="操作日志" Style="{StaticResource CardTitleStyle}"/>
                    <TextBox Style="{StaticResource LogTextBoxStyle}" Text="{Binding OperationLog}"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>