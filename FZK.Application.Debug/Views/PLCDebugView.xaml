<UserControl x:Class="FZK.Application.Debug.Views.PLCDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FZK.Application.Debug.Views"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900"
             xmlns:prism="http://prismlibrary.com/"             
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks" 
             prism:ViewModelLocator.AutoWireViewModel="True"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:vm="clr-namespace:FZK.Application.Debug.ViewModels"
             d:DataContext="{d:DesignInstance vm:PLCDebugViewModel}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Page.Background.Color}">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. 连接配置卡片 -->
            <Border Grid.Row="0" Style="{StaticResource Boder.MainStatus.CardStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource 连接配置}" Style="{StaticResource CardTitleStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource IP地址}" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Column="1" Style="{StaticResource FormTextBoxStyle}" Text="{Binding IPAdress}" Width="120"/>

                        <TextBlock Grid.Column="2" Text="{DynamicResource 网络号}" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Column="3" Style="{StaticResource FormTextBoxStyle}" Text="{Binding NetworkNo}" Width="60"/>

                        <TextBlock Grid.Column="4" Text="{DynamicResource 节点号}" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Column="5" Style="{StaticResource FormTextBoxStyle}" Text="{Binding NodeNo}" Width="60"/>

                        <TextBlock Grid.Column="6" Text="{DynamicResource 端口}" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Column="7" Style="{StaticResource FormTextBoxStyle}" Text="{Binding Port}" Width="80"/>

                        <StackPanel Grid.Column="8" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="{DynamicResource 连接}" Style="{StaticResource Button.Main.SuccessButtonStyle}" Command="{Binding ConnectPlcCommand}" Margin="5"/>
                            <Button Content="{DynamicResource 断开}" Style="{StaticResource Button.Main.DangerButtonStyle}" Command="{Binding DisconnectPlcCommand}" 
                                    IsEnabled="{Binding Connected}" Margin="5"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 2. 设备状态卡片 -->
            <Border Grid.Row="1" Style="{StaticResource Boder.MainStatus.CardStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource 设备状态}" Style="{StaticResource CardTitleStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource 连接状态}" Style="{StaticResource FormLabelStyle}"/>
                        <Ellipse Grid.Column="1" Style="{StaticResource StatusDotStyle}" Fill="{Binding Connected, Converter={StaticResource BoolToColorConverter}}"/>

                        <TextBlock Grid.Column="2" Text="{DynamicResource 心跳值}" Style="{StaticResource FormLabelStyle}" Margin="20,0,0,0"/>
                        <TextBlock Grid.Column="3" Text="{Binding HeartbeatValue}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>

                        <Ellipse Grid.Column="4" Style="{StaticResource StatusDotStyle}" Fill="{Binding HeartbeatStateColor}" Margin="20,0,5,0"/>
                        <TextBlock Grid.Column="5" Text="{Binding HeartbeatStateText}" FontSize="12" Foreground="Gray" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 3. 地址监听卡片 -->
            <Border Grid.Row="2" Style="{StaticResource Boder.MainStatus.CardStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource 地址监听}" Style="{StaticResource CardTitleStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource 地址类型}" Style="{StaticResource FormLabelStyle}"/>
                        <ComboBox Grid.Column="1" Style="{StaticResource FormComboBoxStyle}" Width="100" 
                                  ItemsSource="{Binding MonitorAddressTypes}" SelectedItem="{Binding MonitorAddressType}"/>

                        <TextBlock Grid.Column="2" Text="{DynamicResource 地址}" Style="{StaticResource FormLabelStyle}" Margin="10,0,0,0"/>
                        <TextBox Grid.Column="3" Style="{StaticResource FormTextBoxStyle}" Width="100" Text="{Binding MonitorAddress}"/>

                        <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="10,0,0,0">
                            <Button Content="{DynamicResource 开始监听}" Style="{StaticResource Button.Main.SuccessButtonStyle}" Command="{Binding StartMonitorCommand}" 
                                    IsEnabled="{Binding IsPlcConnected}" Margin="0,0,5,0"/>
                            <Button Content="{DynamicResource 停止监听}" Style="{StaticResource Button.Main.DangerButtonStyle}" Command="{Binding StopMonitorCommand}" 
                                    IsEnabled="{Binding IsMonitoring}" Margin="5,0,0,0"/>
                        </StackPanel>

                        <TextBlock Grid.Column="5" Text="{DynamicResource 当前值}" Style="{StaticResource FormLabelStyle}" Margin="20,0,0,0"/>
                        <TextBlock Grid.Column="6" Text="{Binding MonitorValue}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="7" Text="{Binding MonitorTips}" FontSize="12" Foreground="Blue" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 4. 单地址读写卡片 -->
            <Border Grid.Row="3" Style="{StaticResource Boder.MainStatus.CardStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource 单地址读写}" Style="{StaticResource CardTitleStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{DynamicResource 地址类型}" Style="{StaticResource FormLabelStyle}"/>
                        <ComboBox Grid.Column="1" Style="{StaticResource FormComboBoxStyle}" Width="100" 
                                  ItemsSource="{Binding PLCRegisterTypes}" SelectedItem="{Binding RegisterTypes}"/>

                        <TextBlock Grid.Column="2" Text="{DynamicResource 地址}" Style="{StaticResource FormLabelStyle}" Margin="10,0,0,0"/>
                        <TextBox Grid.Column="3" Style="{StaticResource FormTextBoxStyle}" Width="100" Text="{Binding RwAddress, UpdateSourceTrigger=PropertyChanged}"/>

                        <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="10,0,0,0">
                            <Button Content="{DynamicResource 读取}" Style="{StaticResource Button.Main.ManualButtonStyle}" Command="{Binding ReadCommand}" 
                                    IsEnabled="{Binding IsPlcConnected}" Margin="0,0,5,0"/>
                            <TextBox Grid.Column="5" Style="{StaticResource ReadOnlyTextBoxStyle}" Width="80" Text="{Binding RwReadValue}" Margin="5,0"/>
                        </StackPanel>

                        <TextBlock Grid.Column="6" Text="{DynamicResource 写入值}" Style="{StaticResource FormLabelStyle}" Margin="20,0,0,0"/>
                        <TextBox Grid.Column="7" Style="{StaticResource FormTextBoxStyle}" Width="80" Text="{Binding RwWriteValue, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                        <Button Grid.Column="8" Content="{DynamicResource 写入}" Style="{StaticResource Button.Main.SuccessButtonStyle}" 
                                Command="{Binding WriteCommand}" IsEnabled="{Binding IsPlcConnected}" Margin="5"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 5. 操作日志卡片 -->
            <Border Grid.Row="4" Style="{StaticResource Boder.MainStatus.CardStyle}">
                <StackPanel>
                    <TextBlock Text="{DynamicResource 操作日志}" Style="{StaticResource CardTitleStyle}"/>
                    <TextBox Style="{StaticResource LogTextBoxStyle}" Text="{Binding OperationLog}"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>