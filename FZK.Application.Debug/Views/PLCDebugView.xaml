<UserControl x:Class="FZK.Application.Debug.Views.PLCDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FZK.Application.Debug.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
              xmlns:prism="http://prismlibrary.com/"             
			 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks" 
			 prism:ViewModelLocator.AutoWireViewModel="True"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:vm="clr-namespace:FZK.Application.Debug.ViewModels"
             d:DataContext="{d:DesignInstance vm:PLCDebugViewModel}"
             >
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <GroupBox Grid.Row="0" Header="连接配置">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="IP地址："/>
                <TextBox Grid.Column="1" Width="120" Text="{Binding IPAdress}"/>
                
                <Label Grid.Column="2" Content="网络号："/>
                <TextBox Grid.Column="3" Text="{Binding NetworkNo}" MaxLength="2" Width="60"/>

                <Label Grid.Column="4" Content="节点号："/>
                <TextBox Grid.Column="5" Text="{Binding NodeNo}" MaxLength="2" Width="60"/>

                <Label Grid.Column="6" Content="端口："/>
                <TextBox Grid.Column="7" Text="{Binding Port}" MaxLength="5" Width="80"/>

                <Button Grid.Column="8" Content="连接"
                        Command="{Binding ConnectPlcCommand}"
                        Background="LightGreen" Margin="5"
                        />
                
                <Button Grid.Column="9" Content="断开" 
                        Command="{Binding DisconnectPlcCommand}" 
                        Background="LightCoral" Margin="5"
                         Visibility="{Binding Connected,Converter={StaticResource BoolToVisibleConvert}}"
                        />
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="1" Header="设备状态">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- 连接状态 -->
                <Label Grid.Column="0" Content="连接状态："/>
               
                <Ellipse Grid.Column="2" Width="15" Height="15" Margin="5"
                         Fill="{Binding Connected,Converter={StaticResource BoolToColorConverter}}"  />

                <!-- 心跳状态 -->
                <Label Grid.Column="3" Content="心跳值(DM9999)："/>
                <TextBlock Grid.Column="4" Text="{Binding HeartbeatValue}" FontSize="14"/>
                <Ellipse Grid.Column="5" Width="15" Height="15" Margin="5"/>
                <Label Grid.Column="6" Content="心跳状态："/>
                <TextBlock Grid.Column="7"  FontSize="14" FontWeight="Bold"
                           Text="" 
                           Foreground="White"/>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="2" Header="地址监听">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="地址类型："/>
                <ComboBox Grid.Column="1" Width="80" SelectedItem="{Binding MonitorAddressType}">
                    <ComboBoxItem>DM</ComboBoxItem>
                    <ComboBoxItem>CIO</ComboBoxItem>
                </ComboBox>
                <Label Grid.Column="2" Content="地址："/>
                <TextBox Grid.Column="3" Text="{Binding MonitorAddress}" Width="100"/>
                <Button Grid.Column="4" Content="开始监听" Command="{Binding StartMonitorCommand}" 
                        IsEnabled="{Binding IsPlcConnected}" Background="LightBlue" Margin="5"/>
                <Button Grid.Column="5" Content="停止监听" Command="{Binding StopMonitorCommand}" 
                        IsEnabled="{Binding IsMonitoring}" Background="LightSalmon" Margin="5"/>

                <Label Grid.Column="6" Content="当前值："/>
                <TextBlock Grid.Column="7" Text="{Binding MonitorValue}" FontSize="14" FontWeight="Bold"/>
              
                <Label Grid.Column="8" Content="状态："/>
                <TextBlock Grid.Column="9" Text="{Binding MonitorTips}" FontSize="12" Foreground="Blue"/>

            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="3" Header="单地址读写">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Content="地址类型："/>
                <ComboBox Grid.Column="1" Width="80" ItemsSource="{Binding PLCRegisterTypes}"  SelectedItem="{Binding RegisterTypes}">
                   
                </ComboBox>
                <Label Grid.Column="2" Content="地址："/>
                <TextBox Grid.Column="3" Text="{Binding RwAddress,UpdateSourceTrigger=PropertyChanged}" Width="100"/>

                <Button Grid.Column="4" Content="读取" Command="{Binding ReadCommand}" 
                        IsEnabled="{Binding IsPlcConnected}" Background="LightSkyBlue" Margin="5"/>
                <Label Grid.Column="5" Content="读取值："/>
                <TextBox Grid.Column="6" 
                         Width="60"
                         Text="{Binding RwReadValue}" 
                         IsReadOnly="True" Background="LightGray"/>

                <Label Grid.Column="7" Content="写入值："/>
                <TextBox Grid.Column="8" Width="60" Text="{Binding RwWriteValue,UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="9" Content="写入" Command="{Binding WriteCommand}" 
                        IsEnabled="{Binding IsPlcConnected}" Background="LightGreen" Margin="5"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="4" Header="操作日志">
            <TextBox Text="{Binding OperationLog}" IsReadOnly="True" 
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     Background="#F5F5F5" FontFamily="Consolas" FontSize="11"/>
        </GroupBox>
    </Grid>
</UserControl>
