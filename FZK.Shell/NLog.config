<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true">

	<targets>
		<!-- 错误日志：每天一个文件，保留最近30个 -->
		<target xsi:type="File"
				name="errorFile"
				fileName="${basedir}/logs/error/error-${shortdate}.log"
				layout="${longdate} | ${level:uppercase=true} | ${logger} | ${message} ${exception:format=tostring}"
				archiveAboveSize="10485760"
				maxArchiveFiles="30" />

		<!-- 信息日志：每天一个文件，保留最近30个 -->
		<target xsi:type="File"
				name="infoFile"
				fileName="${basedir}/logs/info/info-${shortdate}.log"
				layout="${longdate} | ${level:uppercase=true} | ${logger} | ${message}"
				archiveAboveSize="10485760"
				maxArchiveFiles="30" />

		<!-- 调试日志：每天一个文件，保留最近30个 -->
		<target xsi:type="File"
				name="debugFile"
				fileName="${basedir}/logs/debug/debug-${shortdate}.log"
				layout="${longdate} | ${level:uppercase=true} | ${logger} | ${message} ${exception:format=tostring}"
				archiveAboveSize="10485760"
				maxArchiveFiles="30" />
		<target xsi:type="File"
			name="traceFile"
			fileName="${basedir}/logs/trace/trace-${shortdate}.log"
			layout="${longdate} | ${level:uppercase=true} | ${logger} | ${message} ${exception:format=tostring}"
			archiveAboveSize="10485760"
			maxArchiveFiles="30" />
	</targets>

	<rules>
		<!-- Error 和 Fatal 写入 errorFile，并停止后续匹配 -->
		<logger name="*" level="Error" writeTo="errorFile" final="true" />
		<logger name="*" level="Fatal" writeTo="errorFile" final="true" />

		<!-- Warn 和 Info 写入 infoFile，并停止（避免进入 debugFile） -->
		<logger name="*" level="Warn" writeTo="infoFile" final="true" />
		<logger name="*" level="Info" writeTo="infoFile" final="true" />

		<!-- Debug 写入 debugFile，并停止（避免进入 trace 目标） -->
		<logger name="*" level="Debug" writeTo="debugFile" final="true" />

		<!-- Trace 写入一个独立的目标（如需记录 Trace，需先定义 target） -->

		<logger name="*" level="Trace" writeTo="traceFile" final="true" />

	</rules>
</nlog>