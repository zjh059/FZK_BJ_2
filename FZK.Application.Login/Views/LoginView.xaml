<UserControl x:Class="FZK.Application.Login.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FZK.Application.Login.Views"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:vm="clr-namespace:FZK.Application.Login.ViewModels"
             d:DataContext="{d:DesignInstance vm:LoginViewModel}"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             Background="{StaticResource FZK.Login.Background.Color}"
             d:DesignHeight="900" d:DesignWidth="1500" 
             >
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="1" Width="1" Background="AliceBlue" Margin="0 300 0 300"/>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="焊接上下料" TextWrapping="Wrap" FontSize="80" Foreground="White" VerticalAlignment="Center"/>
            <TextBlock Text="扫码系统" TextWrapping="Wrap" FontSize="80" Foreground="White" VerticalAlignment="Center"/>
        </StackPanel>
        <Grid Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <iconPacks:PackIconModern Grid.Row="0" Grid.ColumnSpan="2" Kind="CameraAuto" 
                                      Foreground="White" Width="80" Height="60"/>
            <TextBox Grid.Row="1" Width="300" Height="45" FontSize="30" Margin="15"
                     Text="{Binding User.UserName,UpdateSourceTrigger=PropertyChanged}"/>
            <TextBox  Grid.Row="2" Width="300" Height="45" FontSize="30" Margin="15"
                           Text="{Binding User.Password,UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="登录" Grid.Column="1" Grid.Row="1" Grid.RowSpan="2" Width="125" Height="125" FontSize="30" Margin="15" Command="{Binding LoginCommand}"/>
        </Grid>
    </Grid>
</UserControl>
