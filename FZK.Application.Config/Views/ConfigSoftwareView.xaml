<UserControl x:Class="FZK.Application.Config.Views.ConfigSoftwareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FZK.Application.Config.Views"
             mc:Ignorable="d" 
             xmlns:prism="http://prismlibrary.com/"             
			 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks" 
			 prism:ViewModelLocator.AutoWireViewModel="True"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:vm="clr-namespace:FZK.Application.Config.ViewModels"
             d:DataContext="{d:DesignInstance vm:ConfigSoftwareViewModel}"
             d:DesignHeight="450" d:DesignWidth="800">
    <!--<i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadedCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>-->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Border Background="#F5F5F5">
            <TextBlock Text="系统设置" VerticalAlignment="Center" Margin="15 0"/>
        </Border>
        <Border Grid.Row="1" Margin="15">
            <StackPanel >
                <StackPanel Orientation="Horizontal" Margin="30 10 15 0">
                    <TextBlock Text="控制卡IP" Width="100" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBox Height="25" Width="200" Margin="0 0 10 0" 
                             Text="{Binding SystemConfigManager.ControlCardConfig.IpAddress,UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="端口号" Width="100" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBox Height="25" Width="200" Margin="0 0 10 0" 
                             Text="{Binding SystemConfigManager.ControlCardConfig.Port,UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="30 10 15 0">
                    <TextBlock Text="左相机" Width="100" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBox Height="25" Width="200" Margin="0 0 10 0" 
                             Text="{Binding SystemConfigManager.LeftCameraConfig.IpAddress,UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="右相机" Width="100" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBox Height="25" Width="200" Margin="0 0 10 0" 
                             Text="{Binding SystemConfigManager.RightCameraConfig.Port,UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="30 10 15 0">
                    <TextBlock Text="寸动步长mm" Width="100" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBox Height="25" Width="200" Margin="0 0 10 0" 
                             Text="{Binding SystemConfigManager.SoftwareConfig.AxisMoveStepMM,UpdateSourceTrigger=LostFocus}"/>
                    <TextBlock Text="系统标题" Width="100" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBox Height="25" Width="200" Margin="0 0 10 0" 
                             Text="{Binding SystemConfigManager.SoftwareConfig.Title,UpdateSourceTrigger=PropertyChanged}"/>

                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
