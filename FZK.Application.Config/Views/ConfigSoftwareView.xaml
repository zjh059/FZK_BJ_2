<UserControl x:Class="FZK.Application.Config.Views.ConfigSoftwareView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FZK.Application.Config.Views"
             mc:Ignorable="d" 
             xmlns:prism="http://prismlibrary.com/"             
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks" 
             prism:ViewModelLocator.AutoWireViewModel="True"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:vm="clr-namespace:FZK.Application.Config.ViewModels"
             d:DataContext="{d:DesignInstance vm:ConfigSoftwareViewModel}"
             d:DesignHeight="1000" d:DesignWidth="1800">

    <UserControl.Resources>
        <!-- 卡片样式 -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,5,10,5"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#CBD5E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,0,15,0"/>
            <Setter Property="Background" Value="#F7FAFC"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#3182CE"/>
                    <Setter Property="Background" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FormCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,5,15,5"/>
            <Setter Property="Foreground" Value="#2D3748"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F9FAFB">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="White" Margin="0,0,0,20" 
                    BorderThickness="0,0,0,1" BorderBrush="#E2E8F0">
                <TextBlock Text="{DynamicResource 软件配置}" FontSize="20" FontWeight="Bold" 
                           Foreground="#1A202C" Margin="0,10,0,10"/>
            </Border>

            <!-- MES 配置卡片 -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="20">
                <StackPanel>
                    <TextBlock Text="{DynamicResource MES配置}" Style="{StaticResource SectionTitleStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 第一行：测试结果URL + 工位上报URL -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource 测试结果URL}" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource FormTextBoxStyle}" 
                                 Text="{Binding SystemConfigManager.SoftwareConfig.TestResultUrl, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{DynamicResource 工位上报URL}" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="0" Grid.Column="3" Style="{StaticResource FormTextBoxStyle}" 
                                 Text="{Binding SystemConfigManager.SoftwareConfig.ReportStationUrl, UpdateSourceTrigger=PropertyChanged}"/>

                        <!-- 第二行：工位编码 + 初始化URL -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource 工位编码}" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource FormTextBoxStyle}" 
                                 Text="{Binding SystemConfigManager.SoftwareConfig.StationCode, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{DynamicResource 初始化URL}" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="1" Grid.Column="3" Style="{StaticResource FormTextBoxStyle}" 
                                 Text="{Binding SystemConfigManager.SoftwareConfig.InitUrl, UpdateSourceTrigger=PropertyChanged}"/>

                        <!-- 第三行：工位ID + 启用SFC -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource 工位ID}" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource FormTextBoxStyle}" 
                                 Text="{Binding SystemConfigManager.SoftwareConfig.StationID, UpdateSourceTrigger=PropertyChanged}"/>
                        <CheckBox Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" 
                                  Content="{DynamicResource 启用SFC}" Style="{StaticResource FormCheckBoxStyle}"
                                  IsChecked="{Binding SystemConfigManager.SoftwareConfig.IsSFC, UpdateSourceTrigger=PropertyChanged}"/>

                        <!-- 第四行：站点编码 + 用户编码 -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource 站点编码}" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource FormTextBoxStyle}" 
                                 Text="{Binding SystemConfigManager.SoftwareConfig.siteCode, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="{DynamicResource 用户编码}" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="3" Grid.Column="3" Style="{StaticResource FormTextBoxStyle}" 
                                 Text="{Binding SystemConfigManager.SoftwareConfig.userCode, UpdateSourceTrigger=PropertyChanged}"/>

                        <!-- 第五行：密码 -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource 密码}" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Style="{StaticResource FormTextBoxStyle}" 
                                 Text="{Binding SystemConfigManager.SoftwareConfig.password, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 运行参数配置卡片 -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="20">
                <StackPanel>
                    <TextBlock Text="{DynamicResource 运行参数配置}" Style="{StaticResource SectionTitleStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 第一行 -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource PLC读取间隔ms}" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource FormTextBoxStyle}" 
                                 Text="{Binding SystemConfigManager.runConfig.PlcReadInterval}"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{DynamicResource 状态检查间隔ms}" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="0" Grid.Column="3" Style="{StaticResource FormTextBoxStyle}" 
                                 Text="{Binding SystemConfigManager.runConfig.StatusCheckInterval}"/>

                        <!-- 第二行 -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource 最大记录数}" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource FormTextBoxStyle}" 
                                 Text="{Binding SystemConfigManager.runConfig.MaxScanRecords}"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{DynamicResource 扫码重试次数}" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="1" Grid.Column="3" Style="{StaticResource FormTextBoxStyle}" 
                                 Text="{Binding SystemConfigManager.runConfig.ScanRetryCount}"/>

                        <!-- 第三行 -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource 重试延迟ms}" Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource FormTextBoxStyle}" 
                                 Text="{Binding SystemConfigManager.runConfig.ScanRetryDelay}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>