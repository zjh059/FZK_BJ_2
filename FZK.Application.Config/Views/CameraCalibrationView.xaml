<UserControl x:Class="FZK.Application.Config.Views.CameraCalibrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FZK.Application.Config.Views"
             mc:Ignorable="d" 
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:controls="clr-namespace:FZK.Application.UI.Controls;assembly=FZK.Application.UI"
             xmlns:vm="clr-namespace:FZK.Application.Config.ViewModels"
             xmlns:core="clr-namespace:FZK.Core.Models;assembly=FZK.Core"
             d:DataContext="{d:DesignInstance vm:CameraCalibrationViewModel}"
             Background="Transparent"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="1000" d:DesignWidth="1800">
    <Grid Background="White" Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Border Background="#F5F5F5">
            <TextBlock Text="相机标定" VerticalAlignment="Center" Margin="15 0"/>
        </Border>
        <Border Grid.Row="1" Margin="15">
            <Grid Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="700"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="700"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <!--left camera-->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="586"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding LeftSelectRect}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconModern Kind="Camera" Width="30" Height="30" VerticalAlignment="Center"/>
                        <TextBlock Text="左相机" VerticalAlignment="Center" Margin="10 0 0 0" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                    <Border Grid.Row="1">
                        <Border Grid.Row="1">
                            <controls:CameraBox ImageSource="{Binding LeftBitmap.ImageSource}"
                                                IsMouseSelect="True">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="RectChanged">
                                        <prism:InvokeCommandAction Command="{Binding LeftRectChangedCommand}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </controls:CameraBox>
                        </Border>
                    </Border>
                    <StackPanel Grid.Row="2">
                        <Button Content="左相机标定" Height="50" FontSize="18" Margin="0 10 0 15"
                                Command="{Binding CameraCalibrationCommand}"/>
                        <TextBlock FontSize="18" FontWeight="Bold" Margin="0 8">
                            <Run Text="标定结果："/>
                            <Run Text="{Binding LeftPixelToMillimeter}" Foreground="Green"/>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0 8 0 8">
                            <Run Text="上位机中相机标定是一个复杂且精确的过程，需要注意多个方面以确保标定的准确性和可靠性。"/>
                            <Run Text="标定板精度：标定板用于标定的制作精度一定要高，因为精度低的标定板会引入较大的误差。"/>
                            <Run Text="标定板应放置在相机的视场范围内，且要完全覆盖相机的四个角。在采集图像时，标定板应被分别置于相机视野的正中、边缘以及四个角点等处，还要注意保持标定板一定的不同倾斜与旋转，以确保标定的全面性。"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
                <!--right camera-->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="586"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding RightSelectRect}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconModern Kind="Camera" Width="30" Height="30" VerticalAlignment="Center"/>
                        <TextBlock Text="右相机" VerticalAlignment="Center" Margin="10 0 0 0" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                    <Border Grid.Row="1" >
                        <Border Grid.Row="1" >
                            <controls:CameraBox ImageSource="{Binding RightBitmap.ImageSource}"
                                                IsMouseSelect="True">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="RectChanged">
                                        <prism:InvokeCommandAction Command="{Binding RightRectChangedCommand}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </controls:CameraBox>
                        </Border>
                    </Border>
                    <StackPanel Grid.Row="2">
                        <Button Content="右相机标定" Height="50" FontSize="18" Margin="0 10 0 15"
                                Command="{Binding CameraCalibrationCommand}"/>
                        <TextBlock FontSize="18" FontWeight="Bold" Margin="0 8">
                            <Run Text="标定结果："/>
                            <Run Text="{Binding RightPixelToMillimeter}" Foreground="Green"/>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Margin="0 38 0 8">
                            <Run Text="相机稳定性：在标定过程中，相机调好后就不能再动了。稍微的移动都可能导致需要重新标定。"/>
                            <Run Text="图像清晰度：对焦时要考虑到全场的清晰程度，达到一种全场的均衡。这可以通过先把光圈调到最大进行对焦，对焦完成后再把光圈减小来实现。"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
                <!--标定流程-->
                <Grid Grid.Column="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <ScrollViewer MaxHeight="800">
                        <ItemsControl  Margin="25 0 12 0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Height="auto" Padding="8" Background="#F5F5F5" Margin="0 0 0 10" 
                                            BorderThickness="1" BorderBrush="#DFDFDF">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition/>
                                                <ColumnDefinition Width="auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" TextWrapping="Wrap"
                                                       VerticalAlignment="Bottom" Margin="5 0" FontSize="18">
                                                <Run Text="{Binding Content}"/>
                                                <Run Text="{Binding Seconds}"/>
                                                <Run Text="s"/>
                                            </TextBlock>
                                            <mah:MetroProgressBar Grid.Row="1"   Grid.Column="0" Margin="5" Height="1"
                                                                  Value="{Binding Percent}" Foreground="Green"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" FontSize="12"
                                                       VerticalAlignment="Center" Margin="5">
                                                <Run Text="{Binding Percent,StringFormat={}{0:F2}}"/>
                                                <Run Text="%"/>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Button Content="保存" Height="50" FontSize="18" Margin="25 10 25 10" Grid.Row="1"
                            VerticalAlignment="Top" Command="{Binding SaveCommand}"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
