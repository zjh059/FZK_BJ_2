<UserControl x:Class="FZK.Application.Config.Views.ConfigPLCView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FZK.Application.Config.Views"
             mc:Ignorable="d" 
             xmlns:prism="http://prismlibrary.com/"             
			 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks" 
			 prism:ViewModelLocator.AutoWireViewModel="True"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:vm="clr-namespace:FZK.Application.Config.ViewModels"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             d:DataContext="{d:DesignInstance vm:ConfigPLCViewModel}"
             d:DesignHeight="1000" d:DesignWidth="1800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Border Background="#F5F5F5">
            <TextBlock Text="PLC设置" VerticalAlignment="Center" Margin="15 0"/>
        </Border>
        <!--left-->
        <Border Grid.Row="1" Margin="15">
            <StackPanel>
                <!--PLC-->
                
                <StackPanel Orientation="Horizontal" Margin="30 10 15 0">
                    <TextBlock Text="超时时间" Width="100" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBox Height="25" Width="200" Margin="0 0 10 0" 
                               Text="{Binding SystemConfigManager.pLCConfig.Timeout,UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="重连次数" Width="100" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBox Height="25" Width="200" Margin="0 0 10 0" 
                               Text="{Binding SystemConfigManager.pLCConfig.MaxReconnectCount,UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>   
                
                <StackPanel Orientation="Horizontal" Margin="30 10 15 0">
                    <TextBlock Text="重连间隔" Width="100" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBox Height="25" Width="200" Margin="0 0 10 0" 
                               Text="{Binding SystemConfigManager.pLCConfig.ReconnectDelay,UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="心跳间隔" Width="100" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBox Height="25" Width="200" Margin="0 0 10 0" 
                               Text="{Binding SystemConfigManager.pLCConfig.HeartbeatInterval,UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Margin="30 10 15 0">
                    <TextBlock Text="队列长度" Width="100" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBox Height="25" Width="200" Margin="0 0 10 0" 
                               Text="{Binding SystemConfigManager.pLCConfig.MaxSendQueueLength,UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="指令间隔" Width="100" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBox Height="25" Width="200" Margin="0 0 10 0" 
                               Text="{Binding SystemConfigManager.pLCConfig.SendInterval,UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
