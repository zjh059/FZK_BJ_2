        </TabControl>

        <!-- 底部按钮区 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="15">
            <Button Content="保存" Width="80" Height="30" Margin="5" Command="{Binding SaveCommand}"/>
            <Button Content="取消" Width="80" Height="30" Margin="5" Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>