                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="IP地址：" VerticalAlignment="Center" Margin="5"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Margin="5" 
                                     Text="{Binding SystemConfigManager.RightDownScannerConfig.IpAddress, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="端口：" VerticalAlignment="Center" Margin="5"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Margin="5" 
                                     Text="{Binding SystemConfigManager.RightDownScannerConfig.Port, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="方向：" VerticalAlignment="Center" Margin="5"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" Margin="5"
                                      ItemsSource="{Binding Source={StaticResource ScannerTypeEnumValues}}"
                                      SelectedItem="{Binding SystemConfigManager.RightDownScannerConfig.Direction, 
                                UpdateSourceTrigger=PropertyChanged}"/>


                            <TextBlock Grid.Row="3" Grid.Column="0" Text="扫码延迟(ms)：" VerticalAlignment="Center" Margin="5"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Margin="5" 
                                     Text="{Binding SystemConfigManager.RightDownScannerConfig.DelayTime, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="触发指令：" VerticalAlignment="Center" Margin="5"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Margin="5" 
                                     Text="{Binding SystemConfigManager.RightDownScannerConfig.TriggerCommand, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="最大重连次数：" VerticalAlignment="Center" Margin="5"/>
                            <TextBox Grid.Row="5" Grid.Column="1" Margin="5" 
                                     Text="{Binding SystemConfigManager.RightDownScannerConfig.MaxReconnectCount, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="重连延迟(ms)：" VerticalAlignment="Center" Margin="5"/>
                            <TextBox Grid.Row="6" Grid.Column="1" Margin="5" 
                                     Text="{Binding SystemConfigManager.RightDownScannerConfig.ReconnectDelay, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="7" Grid.Column="0" Text="编码名称：" VerticalAlignment="Center" Margin="5"/>
                            <TextBox Grid.Row="7" Grid.Column="1" Margin="5" 
                                     Text="{Binding SystemConfigManager.RightDownScannerConfig.EncodingName, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="码值分隔符：" VerticalAlignment="Center" Margin="5"/>
                            <TextBox Grid.Row="8" Grid.Column="1" Margin="5" 
                                     Text="{Binding SystemConfigManager.RightDownScannerConfig.CodeDelimiter, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="9" Grid.Column="0" Text="SN长度：" VerticalAlignment="Center" Margin="5"/>
                            <TextBox Grid.Row="9" Grid.Column="1" Margin="5" 
                                     Text="{Binding SystemConfigManager.RightDownScannerConfig.SnLength, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 机械臂扫码器 -->
            <TabItem Header="机械臂扫码器">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="IP地址：" VerticalAlignment="Center" Margin="5"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Margin="5" 
                                     Text="{Binding SystemConfigManager.RobotScannerConfig.IpAddress, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="端口：" VerticalAlignment="Center" Margin="5"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Margin="5" 
                                     Text="{Binding SystemConfigManager.RobotScannerConfig.Port, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="方向：" VerticalAlignment="Center" Margin="5"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" Margin="5"
                                        ItemsSource="{Binding Source={StaticResource ScannerTypeEnumValues}}"
                                        SelectedItem="{Binding SystemConfigManager.RobotScannerConfig.Direction, 
                                        UpdateSourceTrigger=PropertyChanged}"/>


                            <TextBlock Grid.Row="3" Grid.Column="0" Text="扫码延迟(ms)：" VerticalAlignment="Center" Margin="5"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Margin="5" 
                                     Text="{Binding SystemConfigManager.RobotScannerConfig.DelayTime, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="触发指令：" VerticalAlignment="Center" Margin="5"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Margin="5" 
                                     Text="{Binding SystemConfigManager.RobotScannerConfig.TriggerCommand, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="最大重连次数：" VerticalAlignment="Center" Margin="5"/>
                            <TextBox Grid.Row="5" Grid.Column="1" Margin="5" 
