                                <TextBlock Grid.Row="3" Grid.Column="2" Text="{DynamicResource 编码名称}" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Grid.Row="3" Grid.Column="3" Style="{StaticResource FormTextBoxStyle}" 
                                         Text="{Binding SystemConfigManager.RobotScannerConfig.EncodingName, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource 码值分隔符}" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Style="{StaticResource FormTextBoxStyle}" 
                                         Text="{Binding SystemConfigManager.RobotScannerConfig.CodeDelimiter, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Grid.Row="4" Grid.Column="2" Text="{DynamicResource SN长度}" Style="{StaticResource FormLabelStyle}"/>
                                <TextBox Grid.Row="4" Grid.Column="3" Style="{StaticResource FormTextBoxStyle}" 
                                         Text="{Binding SystemConfigManager.RobotScannerConfig.SnLength, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </TabItem>
            </TabControl>

            <!-- 底部按钮区 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="{DynamicResource 保存}" Width="80" Height="32" Margin="5" 
                        Command="{Binding SaveCommand}"
                        Background="#3182CE" Foreground="White" 
                        BorderThickness="0" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="{DynamicResource 取消}" Width="80" Height="32" Margin="5" 
                        Command="{Binding CancelCommand}"
                        Background="#E2E8F0" Foreground="#2D3748" 
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>