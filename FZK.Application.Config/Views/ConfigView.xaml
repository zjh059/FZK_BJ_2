<UserControl x:Class="FZK.Application.Config.Views.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FZK.Application.Config.Views"
             xmlns:prism="http://prismlibrary.com/"             
			 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks" 
			 prism:ViewModelLocator.AutoWireViewModel="True"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:vm="clr-namespace:FZK.Application.Config.ViewModels"
             xmlns:core="clr-namespace:FZK.Core.Models;assembly=FZK.Core"
             
             d:DataContext="{d:DesignInstance vm:ConfigViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadedCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <StackPanel Background="White">
            <RadioButton Content="{DynamicResource IP设置}"
                         Command="{Binding NavigatonToViewCommand}"
                         Style="{StaticResource RadioButton.Menu.Config.Style}"
                         CommandParameter="{x:Static core:Names.ConfigSoftwareView}">
                <RadioButton.Tag>
                    <iconPacks:PackIconMaterialDesign Kind="KeyboardArrowRight" Width="20" Height="20"/>
                </RadioButton.Tag>
            </RadioButton>
            <RadioButton Content="{DynamicResource PLC设置}"
                         Command="{Binding NavigatonToViewCommand}"
                         CommandParameter="{x:Static core:Names.ConfigPLCView}"
                         Style="{StaticResource RadioButton.Menu.Config.Style}"
                         >
                <RadioButton.Tag>
                    <iconPacks:PackIconMaterialDesign Kind="KeyboardArrowRight" Width="20" Height="20"/>
                </RadioButton.Tag>
            </RadioButton>
            <RadioButton Content="{DynamicResource 扫码设置}"
                         Command="{Binding NavigatonToViewCommand}"
                         CommandParameter="{x:Static core:Names.ConfigScannerView}"
                          Style="{StaticResource RadioButton.Menu.Config.Style}"
                         >
                <RadioButton.Tag>
                    <iconPacks:PackIconMaterialDesign Kind="KeyboardArrowRight" Width="20" Height="20"/>
                </RadioButton.Tag>
            </RadioButton>

            <RadioButton Content="{DynamicResource Robot设置}"
                         Command="{Binding NavigatonToViewCommand}"
                         CommandParameter="{x:Static core:Names.ConfigRobotView}"
                         Style="{StaticResource RadioButton.Menu.Config.Style}"
                         >
                <RadioButton.Tag>
                    <iconPacks:PackIconMaterialDesign Kind="KeyboardArrowRight" Width="20" Height="20"/>
                </RadioButton.Tag>
            </RadioButton>

            <RadioButton Content="{DynamicResource 用户设置}"
                         Command="{Binding NavigatonToViewCommand}"
                         CommandParameter="{x:Static core:Names.ConfigUserView}"
                          Style="{StaticResource RadioButton.Menu.Config.Style}"
                         >
                <RadioButton.Tag>
                    <iconPacks:PackIconMaterialDesign Kind="KeyboardArrowRight" Width="20" Height="20"/>
                </RadioButton.Tag>
            </RadioButton>

            <RadioButton Content="{DynamicResource 保存}"
                         Command="{Binding SaveConfigCommand}"
                          Style="{StaticResource RadioButton.Menu.Config.Style}"
                         >
                <RadioButton.Tag>
                    <iconPacks:PackIconMaterialDesign Kind="KeyboardArrowRight" Width="20" Height="20"/>
                </RadioButton.Tag>
            </RadioButton>
        </StackPanel>
        <ContentControl Grid.Column="1" prism:RegionManager.RegionName="{x:Static core:Names.ConfigRegion}"/>
    </Grid>
</UserControl>