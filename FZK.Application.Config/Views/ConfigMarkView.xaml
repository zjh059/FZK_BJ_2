<UserControl x:Class="FZK.Application.Config.Views.ConfigMarkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FZK.Application.Config.Views"
             mc:Ignorable="d" 
             xmlns:prism="http://prismlibrary.com/"             
			 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks" 
			 prism:ViewModelLocator.AutoWireViewModel="True"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:vm="clr-namespace:FZK.Application.Config.ViewModels"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             d:DataContext="{d:DesignInstance vm:ConfigMarkViewModel}"
             d:DesignHeight="1000" d:DesignWidth="1800">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadedCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>
        <!--left-->
        <Grid Grid.Column="0" Background="White" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="45"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Border Background="#F5F5F5">
                <TextBlock Text="左相机ROI参数" VerticalAlignment="Center" Margin="15 0"/>
            </Border>
            <Border Grid.Row="1" Margin="15">
                <ItemsControl  Margin="8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#F6F6F6" BorderBrush="#DFDFDF" BorderThickness="1" Margin="0 0 0 10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Row="0" Grid.Column="0" Margin="8" Padding="8" BorderBrush="Gray" BorderThickness="0 0 1 0">
                                        <TextBlock FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                                             <Run Text="{Binding TapeWidth}"/>
                                              <Run Text="mm"/>
                                        </TextBlock>
                                    </Border>
                                    <Grid Grid.Row="0" Grid.Column="1" Margin="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="MARK坐标" Margin="0 15" 
                HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="("/>
                                            <TextBox Text="{Binding Mark.X}" Margin="0 0 10 0"/>
                                            <TextBox Text="{Binding Mark.Y}" Margin="0 0 10 0"/>
                                            <TextBlock Text=") 半径:"/>
                                            <TextBox Text="{Binding Mark.Radius}" Margin="0 0 10 0"/>
                                            <TextBlock Text=" 搜索半径:"/>
                                            <TextBox Text="{Binding SearchRadius}" Margin="0 0 10 0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="齿轮孔区域" Margin="0 15"
             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="("/>
                                            <TextBox Text="{Binding Circle.X}" Margin="0 0 10 0"/>
                                            <TextBox Text="{Binding Circle.Y}" Margin="0 0 10 0"/>
                                            <TextBox Text="{Binding Circle.Width}" Margin="0 0 10 0"/>
                                            <TextBox Text="{Binding Circle.Height}" Margin="0 0 10 0"/>
                                            <TextBlock Text=")"/>
                                            <TextBox Text="{Binding X1}" Margin="0 0 10 0"/>
                                            <TextBox Text="{Binding X2}" Margin="0 0 10 0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="元件区域" Margin="0 15"
             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="("/>
                                            <TextBox Text="{Binding Element.X}" Margin="0 0 10 0"/>
                                            <TextBox Text="{Binding Element.Y}" Margin="0 0 10 0"/>
                                            <TextBox Text="{Binding Element.Width}" Margin="0 0 10 0"/>
                                            <TextBox Text="{Binding Element.Height}" Margin="0 0 10 0"/>
                                            <TextBlock Text=")"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </Grid>
        <!--right-->
        <Grid Grid.Column="1" Background="White" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="45"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Border Background="#F5F5F5">
                <TextBlock Text="右相机ROI参数" VerticalAlignment="Center" Margin="15 0"/>
            </Border>
            <Border Grid.Row="1" Margin="15">
                <ItemsControl  Margin="8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#F6F6F6" BorderBrush="#DFDFDF" BorderThickness="1" Margin="0 0 0 10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Row="0" Grid.Column="0" Margin="8" Padding="8" BorderBrush="Gray" BorderThickness="0 0 1 0">
                                        <TextBlock FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Run Text="{Binding TapeWidth}"/>
                                        <Run Text="mm"/>
                                        </TextBlock>
                                    </Border>
                                    <Grid Grid.Row="0" Grid.Column="1" Margin="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="MARK坐标" Margin="0 15" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="("/>
                                            <TextBox Text="{Binding Mark.X}" Margin="0 0 10 0"/>
                                            <TextBox Text="{Binding Mark.Y}" Margin="0 0 10 0"/>
                                            <TextBlock Text=") 半径:"/>
                                            <TextBox Text="{Binding Mark.Radius}" Margin="0 0 10 0"/>
                                            <TextBlock Text=" 搜索半径:"/>
                                            <TextBox Text="{Binding SearchRadius}" Margin="0 0 10 0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="齿轮孔区域" Margin="0 15"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="("/>
                                            <TextBox Text="{Binding Circle.X}" Margin="0 0 10 0"/>
                                            <TextBox Text="{Binding Circle.Y}" Margin="0 0 10 0"/>
                                            <TextBox Text="{Binding Circle.Width}" Margin="0 0 10 0"/>
                                            <TextBox Text="{Binding Circle.Height}" Margin="0 0 10 0"/>
                                            <TextBlock Text=")"/>
                                            <TextBox Text="{Binding X1}" Margin="0 0 10 0"/>
                                            <TextBox Text="{Binding X2}" Margin="0 0 10 0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="元件区域" Margin="0 15"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="("/>
                                            <TextBox Text="{Binding Element.X}" Margin="0 0 10 0"/>
                                            <TextBox Text="{Binding Element.Y}" Margin="0 0 10 0"/>
                                            <TextBox Text="{Binding Element.Width}" Margin="0 0 10 0"/>
                                            <TextBox Text="{Binding Element.Height}" Margin="0 0 10 0"/>
                                            <TextBlock Text=")"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </Grid>
        <!--process-->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition  Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Button Content="开始搜索MARK点" Height="50" FontSize="18" Margin="8"
                   Command="{Binding FindMarkCommad}"/>
            <ItemsControl Grid.Row="1"  Margin="8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Height="auto" Padding="8" Background="#F5F5F5" Margin="0 0 0 10" 
                       BorderThickness="1" BorderBrush="#DFDFDF">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" TextWrapping="Wrap"
                        VerticalAlignment="Bottom" Margin="5 0" FontSize="18">
                                    <Run Text="{Binding Content}"/>
                                    <Run Text="{Binding Seconds}"/>
                                    <Run Text="s"/>
                                </TextBlock>
                                <mah:MetroProgressBar Grid.Row="1"   Grid.Column="0" Margin="5" Height="1"
                                   Value="{Binding Percent}" Foreground="Green"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" FontSize="12"
                        VerticalAlignment="Center" Margin="5">
                                 <Run Text="{Binding Percent,StringFormat={}{0:F2}}"/>
                                 <Run Text="%"/>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Grid>
</UserControl>
