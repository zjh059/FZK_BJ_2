<UserControl x:Class="FZK.Application.Config.Views.ConfigRobotView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FZK.Application.Config.Views"
             mc:Ignorable="d" 
             xmlns:vm="clr-namespace:FZK.Application.Config.ViewModels"
             xmlns:core="clr-namespace:FZK.Core.Models;assembly=FZK.Core"
             d:DataContext="{d:DesignInstance vm:ConfigRobotViewModel}"
             Background="Transparent"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="1000" d:DesignWidth="1800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Border Background="#F5F5F5">
            <TextBlock Text="机械手设置" VerticalAlignment="Center" Margin="15 0"/>
        </Border>
        <Border Grid.Row="1" Margin="15">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="30 10 15 0">
                    <TextBlock Text="超时时间" Width="100" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBox Height="25" Width="200" Margin="0 0 10 0" 
                      Text="{Binding SystemConfigManager.robotConfig.Timeout,UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="重连间隔" Width="100" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBox Height="25" Width="200" Margin="0 0 10 0" 
                      Text="{Binding SystemConfigManager.robotConfig.ReconnectDelay,UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="30 10 15 0">
                    <TextBlock Text="重连次数" Width="100" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBox Height="25" Width="200" Margin="0 0 10 0" 
                      Text="{Binding SystemConfigManager.robotConfig.MaxReconnectCount,UpdateSourceTrigger=PropertyChanged}"/>

                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="30 10 15 0">
                    <TextBlock Text="心跳间隔" Width="100" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBox Height="25" Width="200" Margin="0 0 10 0" 
                      Text="{Binding SystemConfigManager.robotConfig.HeartbeatInterval,UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="心跳指令" Width="100" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBox Height="25" Width="200" Margin="0 0 10 0" 
                      Text="{Binding SystemConfigManager.robotConfig.HeartbeatCommand,UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Margin="30 10 15 0">
                    <TextBlock Text="响应内容" Width="100" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBox Height="25" Width="200" Margin="0 0 10 0" 
                      Text="{Binding SystemConfigManager.robotConfig.HeartbeatResponse,UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="指令超时时间" Width="100" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBox Height="25" Width="200" Margin="0 0 10 0" 
                      Text="{Binding SystemConfigManager.robotConfig.CommandTimeout,UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="30 10 15 0">


                    <TextBlock Text="指令重发次数" Width="100" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBox Height="25" Width="200" Margin="0 0 10 0" 
                      Text="{Binding SystemConfigManager.robotConfig.CommandRetryCount,UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="指令重发延迟" Width="100" VerticalAlignment="Center" Margin="0 0 10 0"/>
                    <TextBox Height="25" Width="200" Margin="0 0 10 0" 
                      Text="{Binding SystemConfigManager.robotConfig.CommandRetryDelay,UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
