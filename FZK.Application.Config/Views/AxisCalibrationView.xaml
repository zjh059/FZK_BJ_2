<UserControl x:Class="FZK.Application.Config.Views.AxisCalibrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FZK.Application.Config.Views"
             mc:Ignorable="d" 
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:controls="clr-namespace:FZK.Application.UI.Controls;assembly=FZK.Application.UI"
             xmlns:vm="clr-namespace:FZK.Application.Config.ViewModels"
             xmlns:core="clr-namespace:FZK.Core.Models;assembly=FZK.Core"
             d:DataContext="{d:DesignInstance vm:AxisCalibrationViewModel}"
             Background="Transparent"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid Background="White" Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Border Background="#F5F5F5">
            <TextBlock Text="XY轴世界坐标系标定" VerticalAlignment="Center" Margin="15 0"/>
        </Border>
        <Border Grid.Row="1">
            <Grid Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="700"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="700"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <!--left camera-->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="586"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconModern Kind="Camera" Width="30" Height="30" VerticalAlignment="Center" Margin="10 0 0 0"/>
                        <TextBlock Text="左相机" VerticalAlignment="Center" Margin="10 0 0 0" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                    <Border Grid.Row="1"  >
                        <Border   >
                            <controls:CameraBox ImageSource="{Binding LeftBitmap.ImageSource}" IsMouseSelect="True">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="RectChanged">
                                        <prism:InvokeCommandAction Command="{Binding LeftRectChangedCommand}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </controls:CameraBox>
                        </Border>
                    </Border>
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>

                        </Grid.RowDefinitions>
                        <Button Grid.Row="0" Grid.Column="0" Height="60" Margin="0 10 0 10"
                                Command="{Binding LeftPointCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="16">
                                    <Run Text="0拾取"/>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="0" Grid.Column="2" Height="60" Margin="0 10 0 10"
                                Command="{Binding LeftPointCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="16">
                                    <Run Text="1拾取"/>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="1" Grid.Column="0" Height="60" Margin="0 10 0 10"
                                Command="{Binding LeftPointCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="16">
                                    <Run Text="2拾取"/>
                                  
                                </TextBlock>
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="1" Grid.Column="2" Height="60" Margin="0 10 0 10"
                                Command="{Binding LeftPointCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="16">
                                    <Run Text="3拾取"/>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="2" Grid.Column="0" Height="60" Margin="0 10 0 10"
                                Command="{Binding LeftPointCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="16">
                                    <Run Text="4拾取"/>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="2" Grid.Column="2" Height="60" Margin="0 10 0 10"
                                Command="{Binding LeftPointCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="16">
                                    <Run Text="5拾取"/>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>

                <!--right camera-->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="586"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconModern Kind="Camera" Width="30" Height="30" VerticalAlignment="Center" Margin="10 0 0 0"/>
                        <TextBlock Text="右相机" VerticalAlignment="Center" Margin="10 0 0 0" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                    <Border Grid.Row="1">
                        <Border >
                            <controls:CameraBox ImageSource="{Binding RightBitmap.ImageSource}" IsMouseSelect="True">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="RectChanged">
                                        <prism:InvokeCommandAction Command="{Binding RightRectChangedCommand}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </controls:CameraBox>
                        </Border>
                    </Border>
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>

                        </Grid.RowDefinitions>
                        <Button Grid.Row="0" Grid.Column="0" Height="60" Margin="0 10 0 10"
                                Command="{Binding RightPointCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="16">
                                    <Run Text="0拾取"/>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="0" Grid.Column="2" Height="60" Margin="0 10 0 10"
                                 Command="{Binding RightPointCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="16">
                                    <Run Text="1拾取"/>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="1" Grid.Column="0" Height="60" Margin="0 10 0 10"
                                 Command="{Binding RightPointCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="16">
                                    <Run Text="2拾取"/>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="1" Grid.Column="2" Height="60" Margin="0 10 0 10" 
                                Command="{Binding RightPointCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="16">
                                    <Run Text="3拾取"/>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="2" Grid.Column="0" Height="60" Margin="0 10 0 10"
                                 Command="{Binding RightPointCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="16">
                                    <Run Text="4拾取"/>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="2" Grid.Column="2" Height="60" Margin="0 10 0 10"
                                 Command="{Binding RightPointCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="16">
                                    <Run Text="5拾取"/>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
                <!--button area-->
                <Grid Grid.Column="3" Background="Transparent">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0">
                        <TextBlock Margin="25">
                            <Run Text="X轴位置:"/>
                            <Run Text="{Binding ControlCard.XAxisPostion}"/>
                            <Run Text="Y轴位置:"/>
                            <Run Text="{Binding ControlCard.YAxisPostion}"/>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Row="1">
                        <Button Content="相机拍照" Command="{Binding TakePictureCommand}"
                                Height="50" FontSize="18" Margin="25 10 25 10"/>
                        <TextBlock Text="提示：拍照后，框选6个点，然后计算6个点在平面坐标系中的位置。" 
                                   Margin="25 8" TextWrapping="Wrap"/>
                        <Button Content="坐标计算" Command="{Binding FindPointCommand}"
                                Height="50" FontSize="18" Margin="25 10 25 10"/>
                        <TextBlock Text="提示：根据6个点的先后顺序，移动X轴和Y轴，使探针到达每个点的中心坐标，然后拾取该点坐标值。所有点坐标与X轴和Y轴匹配结束，开始标定" 
                                   Margin="25 8" TextWrapping="Wrap"/>
                        <Button Content="开始标定" Command="{Binding FindMatrixCommand}"
                                Height="50" FontSize="18" Margin="25 10 25 10"/>
                        <TextBlock Text="提示：标定结束后，请保存" 
                                   Margin="25 8" TextWrapping="Wrap"/>
                        <Button Content="保存" Command="{Binding SaveCommand}"
                                Height="50" FontSize="18" Margin="25 10 25 10"/>
                        <ListBox Margin="10 15 0 10" ItemsSource="{Binding Matrixs}" FontSize="12"/>

                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
