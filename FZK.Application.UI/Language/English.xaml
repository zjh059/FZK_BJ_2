<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    <system:String x:Key="用户名">UserName</system:String>
    <system:String x:Key="密码">Password</system:String>
    <system:String x:Key="登录">Login</system:String>
    <system:String x:Key="标题">Upper-Computer-Framework</system:String>
    <system:String x:Key="确定">OK</system:String>
    <system:String x:Key="取消">Cancel</system:String>
    <system:String x:Key="记住密码">Remember password</system:String>
    <system:String x:Key="自动登录">Auto-login</system:String>
</ResourceDictionary>