<UserControl x:Class="FZK.Application.Run.Views.RunView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:converters="clr-namespace:FZK.Application.UI.Converters;assembly=FZK.Application.UI"
             xmlns:vm="clr-namespace:FZK.Application.Run.ViewModels"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1500"
             d:DataContext="{d:DesignInstance vm:RunViewModel}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource Page.Background.Color}">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 顶部标题栏 + 按钮区 -->
            <Border Grid.Row="0" Background="White" Margin="0,0,0,20" 
                    BorderThickness="0,0,0,1" BorderBrush="#E2E8F0">
                <Grid Margin="20,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource 设备运行监控}" FontSize="20" FontWeight="Bold" 
                               Foreground="#1A202C"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <!--<ToggleButton Content="{Binding HardwareModeText}" Style="{StaticResource ToggleButton.Main.Style}"
                                      IsChecked="{Binding IsNoHardwareMode}"/>-->
                        <Button Content="{Binding RunStatusText}" Style="{Binding RunStatusButtonStyle}"
                                Command="{Binding ToggleRunCommand}"/>
                        <Button Content="{DynamicResource 刷新状态}" Style="{StaticResource Button.Main.SuccessButtonStyle}"
                                Command="{Binding RefreshStatusCommand}"/>
                        <Button Content="{DynamicResource 清空日志}" Style="{StaticResource Button.Main.DangerButtonStyle}"
                                Command="{Binding ClearLogCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- PLC寄存器状态监控区 -->
            <Border Grid.Row="1" Style="{StaticResource Boder.MainStatus.CardStyle}" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="{DynamicResource PLC寄存器状态_实时监控}" Style="{StaticResource TextBlock.Run.SubTitleStyle}"/>
                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- 治具1-D0 -->
                        <Border Grid.Column="0" Style="{StaticResource Boder.MainStatus.RegisterBlockStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource 治具1_D0_底导向板扫码}" FontSize="12" TextAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding PlcD0}" Style="{StaticResource Text.Block.StatusLabelStyle}"
                                           Background="{Binding PlcD0, Converter={StaticResource StatusToColorConverter}}"/>
                            </StackPanel>
                        </Border>
                        <!-- 治具1-D1 -->
                        <Border Grid.Column="1" Style="{StaticResource Boder.MainStatus.RegisterBlockStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource 治具1_D1_焊接结果扫码}" FontSize="12" TextAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding PlcD1}" Style="{StaticResource Text.Block.StatusLabelStyle}"
                                           Background="{Binding PlcD1, Converter={StaticResource StatusToColorConverter}}"/>
                            </StackPanel>
                        </Border>
                        <!-- 治具1-D2 -->
                        <Border Grid.Column="2" Style="{StaticResource Boder.MainStatus.RegisterBlockStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource 治具1_D2_清零}" FontSize="12" TextAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding PlcD2}" Style="{StaticResource Text.Block.StatusLabelStyle}"
                                           Background="{Binding PlcD2, Converter={StaticResource StatusToColorConverter}}"/>
                            </StackPanel>
                        </Border>
                        <!-- 治具2-D3 -->
                        <Border Grid.Column="3" Style="{StaticResource Boder.MainStatus.RegisterBlockStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource 治具2_D3_底导向板扫码}" FontSize="12" TextAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding PlcD3}" Style="{StaticResource Text.Block.StatusLabelStyle}"
                                           Background="{Binding PlcD3, Converter={StaticResource StatusToColorConverter}}"/>
                            </StackPanel>
                        </Border>
                        <!-- 治具2-D4 -->
                        <Border Grid.Column="4" Style="{StaticResource Boder.MainStatus.RegisterBlockStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource 治具2_D4_焊接结果扫码}" FontSize="12" TextAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding PlcD4}" Style="{StaticResource Text.Block.StatusLabelStyle}"
                                           Background="{Binding PlcD4, Converter={StaticResource StatusToColorConverter}}"/>
                            </StackPanel>
                        </Border>
                        <!-- 治具2-D5 -->
                        <Border Grid.Column="5" Style="{StaticResource Boder.MainStatus.RegisterBlockStyle}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource 治具2_D5_清零}" FontSize="12" TextAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding PlcD5}" Style="{StaticResource Text.Block.StatusLabelStyle}"
                                           Background="{Binding PlcD5, Converter={StaticResource StatusToColorConverter}}"/>
                            </StackPanel>
                        </Border>
                        <!-- 心跳位 D110 -->
                        <Border Grid.Column="6" Style="{StaticResource Boder.MainStatus.RegisterBlockStyle}" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource 心跳监控_D110}" FontSize="12" TextAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding PlcD110}" Style="{StaticResource Text.Block.StatusLabelStyle}"
                                           Background="{Binding PlcD110, Converter={StaticResource StatusToColorConverter}}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 治具使用次数卡片（两列） -->
            <Grid Grid.Row="2" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource Boder.MainStatus.CardStyle}" Margin="0,0,10,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{DynamicResource 治具1焊接使用次数_D108}" Style="{StaticResource TextBlock.Run.SubTitleStyle}" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Jig1UseCount}" FontSize="32" FontWeight="Bold" Foreground="#3182CE"/>
                            <TextBlock Text="{DynamicResource 次数上限}" FontSize="20" Margin="5,0,0,0" Foreground="#7F8C8D" VerticalAlignment="Bottom"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource Boder.MainStatus.CardStyle}" Margin="10,0,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{DynamicResource 治具2焊接使用次数_D109}" Style="{StaticResource TextBlock.Run.SubTitleStyle}" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Jig2UseCount}" FontSize="32" FontWeight="Bold" Foreground="#3182CE"/>
                            <TextBlock Text="{DynamicResource 次数上限}" FontSize="20" Margin="5,0,0,0" Foreground="#7F8C8D" VerticalAlignment="Bottom"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 左侧扫码记录 + 右侧机械臂状态&日志 -->
            <Grid Grid.Row="3" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="400"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：扫码记录表格 -->
                <Border Grid.Column="0" Style="{StaticResource Boder.MainStatus.CardStyle}" Margin="0,0,15,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="{DynamicResource 扫码记录_实时更新}" Style="{StaticResource TextBlock.Run.SubTitleStyle}" Margin="0,0,0,12"/>
                        <DataGrid Grid.Row="1" Style="{StaticResource DataGrid.Main.Style}"
                                  ItemsSource="{Binding ScanRecords}"
                                  ColumnHeaderStyle="{StaticResource DataGrid.Main.DataGridColumnHeaderStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource 时间}" Binding="{Binding CreateTime, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="150"/>
                                <DataGridTextColumn Header="{DynamicResource 治具编号}" Binding="{Binding JigNo}" Width="80"/>
                                <DataGridTextColumn Header="{DynamicResource 扫码类型}" Binding="{Binding ScanType}" Width="100"/>
                                <DataGridTextColumn Header="{DynamicResource 底板码}" Binding="{Binding BottomCode}" Width="180"/>
                                <DataGridTextColumn Header="{DynamicResource 导向板码}" Binding="{Binding TopCode}" Width="180"/>
                                <DataGridTextColumn Header="{DynamicResource 主板码}" Binding="{Binding SPCode}" Width="140"/>
                                <DataGridTemplateColumn Header="{DynamicResource 扫码结果}" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Result, Converter={StaticResource ResultToTextConverter}}"
                                                       Style="{StaticResource  Text.Block.StatusLabelStyle}"
                                                       Background="{Binding Result, Converter={StaticResource StatusToColorConverter}}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="{DynamicResource 备注}" Binding="{Binding Remark}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- 右侧：机械臂状态 + 运行日志 -->
                <StackPanel Grid.Column="1">
                    <Border Style="{StaticResource Boder.MainStatus.CardStyle}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource 机械臂状态}" Style="{StaticResource TextBlock.Run.SubTitleStyle}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding RobotStatus}" Style="{StaticResource Text.Block.StatusLabelStyle}"
                                       Background="{Binding RobotStatus, Converter={StaticResource StatusToColorConverter}}"
                                       HorizontalAlignment="Left" Width="Auto" MinWidth="100"/>
                            <TextBlock Text="{DynamicResource 当前扫码位}" FontWeight="SemiBold" Margin="0,12,0,0"/>
                            <TextBlock Text="{Binding RobotScanPosition}" Margin="0,2,0,0"/>
                            <TextBlock Text="{DynamicResource 最新报站结果}" FontWeight="SemiBold" Margin="0,12,0,0"/>
                            <TextBlock Text="{Binding RobotReportResult}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Boder.MainStatus.CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="{DynamicResource 设备运行日志}" Style="{StaticResource TextBlock.Run.SubTitleStyle}" Margin="0,0,0,12"/>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Height="280">
                                <TextBlock Text="{Binding RunLog}" FontFamily="Consolas" FontSize="12"
                                           TextWrapping="Wrap" Padding="5"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- 硬件连接状态区 -->
            <Border Grid.Row="4" Style="{StaticResource Boder.MainStatus.CardStyle}" Background="#F9FAFB">
                <StackPanel>
                    <TextBlock Text="{DynamicResource 硬件连接状态_实时监控}" Style="{StaticResource TextBlock.Run.SubTitleStyle}" Margin="0,0,0,12"/>
                    <WrapPanel Margin="0,5,0,0" HorizontalAlignment="Center">
                        <StackPanel Margin="10,0" HorizontalAlignment="Center">
                            <TextBlock Text="{DynamicResource 欧姆龙PLC}" FontSize="12" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding IsPlcConnected, Converter={StaticResource BoolToTextConverter}}" 
                                       Style="{StaticResource Button.HardwareStatus.Style}"
                                       Background="{Binding IsPlcConnected, Converter={StaticResource StatusToColorConverter}}"/>
                        </StackPanel>
                        <StackPanel Margin="10,0" HorizontalAlignment="Center">
                            <TextBlock Text="{DynamicResource 左上扫码枪}" FontSize="12" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding IsLeftUpScannerConnected, Converter={StaticResource BoolToTextConverter}}" 
                                       Style="{StaticResource Button.HardwareStatus.Style}"
                                       Background="{Binding IsLeftUpScannerConnected, Converter={StaticResource StatusToColorConverter}}"/>
                        </StackPanel>
                        <StackPanel Margin="10,0" HorizontalAlignment="Center">
                            <TextBlock Text="{DynamicResource 左下扫码枪}" FontSize="12" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding IsLeftDownScannerConnected, Converter={StaticResource BoolToTextConverter}}" 
                                       Style="{StaticResource Button.HardwareStatus.Style}"
                                       Background="{Binding IsLeftDownScannerConnected, Converter={StaticResource StatusToColorConverter}}"/>
                        </StackPanel>
                        <StackPanel Margin="10,0" HorizontalAlignment="Center">
                            <TextBlock Text="{DynamicResource 右上扫码枪}" FontSize="12" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding IsRightUpScannerConnected, Converter={StaticResource BoolToTextConverter}}" 
                                       Style="{StaticResource Button.HardwareStatus.Style}"
                                       Background="{Binding IsRightUpScannerConnected, Converter={StaticResource StatusToColorConverter}}"/>
                        </StackPanel>
                        <StackPanel Margin="10,0" HorizontalAlignment="Center">
                            <TextBlock Text="{DynamicResource 右下扫码枪}" FontSize="12" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding IsRightDownScannerConnected, Converter={StaticResource BoolToTextConverter}}" 
                                       Style="{StaticResource Button.HardwareStatus.Style}"
                                       Background="{Binding IsRightDownScannerConnected, Converter={StaticResource StatusToColorConverter}}"/>
                        </StackPanel>
                        <StackPanel Margin="10,0" HorizontalAlignment="Center">
                            <TextBlock Text="{DynamicResource 机械臂扫码枪}" FontSize="12" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding IsSPScannerConnected, Converter={StaticResource BoolToTextConverter}}" 
                                       Style="{StaticResource Button.HardwareStatus.Style}"
                                       Background="{Binding IsSPScannerConnected, Converter={StaticResource StatusToColorConverter}}"/>
                        </StackPanel>
                        <StackPanel Margin="10,0" HorizontalAlignment="Center">
                            <TextBlock Text="{DynamicResource EPSON机械臂}" FontSize="12" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding IsRobotConnected, Converter={StaticResource BoolToTextConverter}}" 
                                       Style="{StaticResource Button.HardwareStatus.Style}"
                                       Background="{Binding IsRobotConnected, Converter={StaticResource StatusToColorConverter}}"/>
                        </StackPanel>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>