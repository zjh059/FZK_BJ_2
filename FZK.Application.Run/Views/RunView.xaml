<UserControl x:Class="FZK.Application.Run.Views.RunView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:converters="clr-namespace:FZK.Application.UI.Converters;assembly=FZK.Application.UI"
             xmlns:vm="clr-namespace:FZK.Application.Run.ViewModels"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1500"
             d:DataContext="{d:DesignInstance vm:RunViewModel}">

    <UserControl.Resources>
        <!-- 转换器 -->
        <converters:BoolToVisibleConvert x:Key="BooleanToVisibilityConverter"/>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
        <converters:ResultToTextConverter x:Key="ResultToTextConverter"/>
        <converters:BoolToTextConverter x:Key="BoolToTextConverter" TrueText="已连接" FalseText="未连接"/>

        <!-- 通用阴影 -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="8" ShadowDepth="2" Opacity="0.15" Color="#CCCCCC"/>

        <!-- 标题样式 -->
        <Style x:Key="TitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0 0 0 15"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>

        <!-- 子标题样式 -->
        <Style x:Key="SubTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0 10 0 5"/>
            <Setter Property="Foreground" Value="#34495E"/>
        </Style>

        <!-- 主按钮样式 -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#95A5A6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 成功按钮样式 -->
        <Style x:Key="SuccessButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="2"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#95A5A6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 危险按钮样式 -->
        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="2"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#95A5A6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 手动按钮样式（小尺寸） -->
        <Style x:Key="ManualButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3FC1F7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDC3C7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 切换按钮样式 -->
        <Style x:Key="ToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="2"/>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#95A5A6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 状态标签样式 -->
        <Style x:Key="StatusLabelStyle" TargetType="TextBlock">
            <Setter Property="Padding" Value="5 2"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="25"/>
        </Style>

        <!-- 硬件连接状态标签样式 -->
        <Style x:Key="HardwareStatusLabelStyle" TargetType="TextBlock">
            <Setter Property="Padding" Value="10 5"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- 数据表格样式 -->
        <Style x:Key="DataGridStyle" TargetType="DataGrid">
            <Setter Property="AlternatingRowBackground" Value="#F8F9FA"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="RowHeight" Value="35"/>
            <Setter Property="Margin" Value="0 10 0 0"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        </Style>

        <!-- 表头样式 -->
        <Style x:Key="DataGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#ECF0F1"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0 0 1 1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- 卡片容器样式 -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
            <Setter Property="Padding" Value="15"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. 顶部控制区 -->
        <Grid Grid.Row="0" Margin="0 0 0 15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="镀金片焊接中段设备运行监控" Style="{StaticResource TitleStyle}"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" >
                <ToggleButton Content="{Binding HardwareModeText}" Style="{StaticResource ToggleButtonStyle}"
                              IsChecked="{Binding IsNoHardwareMode}"/>
                <Button Content="{Binding RunStatusText}" Style="{Binding RunStatusButtonStyle}"
                        Command="{Binding ToggleRunCommand}"/>
                <Button Content="刷新状态" Style="{StaticResource SuccessButtonStyle}"
                        Command="{Binding RefreshStatusCommand}"/>
                <Button Content="清空日志" Style="{StaticResource DangerButtonStyle}"
                        Command="{Binding ClearLogCommand}"/>
            </StackPanel>
        </Grid>

        <!-- 2. PLC寄存器状态监控区 -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0 0 0 15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="PLC寄存器状态（实时监控）" Style="{StaticResource SubTitleStyle}"/>
                <Grid Grid.Row="1" Margin="0 5 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- 治具1 -->
                    <Border Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0 0 8 0">
                        <StackPanel>
                            <TextBlock Text="治具1-D0（底/导向板扫码）" FontSize="12" Margin="0 0 0 5" TextAlignment="Center"/>
                            <TextBlock Text="{Binding PlcD0}" Style="{StaticResource StatusLabelStyle}"
                                       Background="{Binding PlcD0, Converter={StaticResource StatusToColorConverter}}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0 0 8 0">
                        <StackPanel>
                            <TextBlock Text="治具1-D1（焊接结果扫码）" FontSize="12" Margin="0 0 0 5" TextAlignment="Center"/>
                            <TextBlock Text="{Binding PlcD1}" Style="{StaticResource StatusLabelStyle}"
                                       Background="{Binding PlcD1, Converter={StaticResource StatusToColorConverter}}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0 0 8 0">
                        <StackPanel>
                            <TextBlock Text="治具1-D2（清零）" FontSize="12" Margin="0 0 0 5" TextAlignment="Center"/>
                            <TextBlock Text="{Binding PlcD2}" Style="{StaticResource StatusLabelStyle}"
                                       Background="{Binding PlcD2, Converter={StaticResource StatusToColorConverter}}"/>
                        </StackPanel>
                    </Border>
                    <!-- 治具2 -->
                    <Border Grid.Column="3" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0 0 8 0">
                        <StackPanel>
                            <TextBlock Text="治具2-D3（底/导向板扫码）" FontSize="12" Margin="0 0 0 5" TextAlignment="Center"/>
                            <TextBlock Text="{Binding PlcD3}" Style="{StaticResource StatusLabelStyle}"
                                       Background="{Binding PlcD3, Converter={StaticResource StatusToColorConverter}}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0 0 8 0">
                        <StackPanel>
                            <TextBlock Text="治具2-D4（焊接结果扫码）" FontSize="12" Margin="0 0 0 5" TextAlignment="Center"/>
                            <TextBlock Text="{Binding PlcD4}" Style="{StaticResource StatusLabelStyle}"
                                       Background="{Binding PlcD4, Converter={StaticResource StatusToColorConverter}}"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="5" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0 0 8 0">
                        <StackPanel>
                            <TextBlock Text="治具2-D5（清零）" FontSize="12" Margin="0 0 0 5" TextAlignment="Center"/>
                            <TextBlock Text="{Binding PlcD5}" Style="{StaticResource StatusLabelStyle}"
                                       Background="{Binding PlcD5, Converter={StaticResource StatusToColorConverter}}"/>
                        </StackPanel>
                    </Border>
                    <!-- 心跳位 -->
                    <Border Grid.Column="6" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="8">
                        <StackPanel>
                            <TextBlock Text="心跳监控 D110" FontSize="12" Margin="0 0 0 5" TextAlignment="Center"/>
                            <TextBlock Text="{Binding PlcD110}" Style="{StaticResource StatusLabelStyle}"
                                       Background="{Binding PlcD110, Converter={StaticResource StatusToColorConverter}}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- 3. 核心数据展示区 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：治具状态 + 扫码记录 -->
            <Grid Grid.Column="0" Margin="0 0 15 0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 治具使用次数卡片 -->
                <Grid Grid.Row="0" Margin="0 0 0 15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0 0 8 0">
                        <StackPanel>
                            <TextBlock Text="治具1焊接使用次数（D108）" Style="{StaticResource SubTitleStyle}" Margin="0 0 0 5"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Jig1UseCount}" FontSize="28" FontWeight="Bold" Foreground="#3498DB"/>
                                <TextBlock Text="/40" FontSize="20" Margin="5 0 0 0" Foreground="#7F8C8D"/>
                            </StackPanel>
                            <Button Content="手动清零" Style="{StaticResource ManualButtonStyle}" Width="100"
                                    Command="{Binding ClearJig1CountCommand}" Margin="0 10 0 0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8 0 0 0">
                        <StackPanel>
                            <TextBlock Text="治具2焊接使用次数（D109）" Style="{StaticResource SubTitleStyle}" Margin="0 0 0 5"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Jig2UseCount}" FontSize="28" FontWeight="Bold" Foreground="#3498DB"/>
                                <TextBlock Text="/40" FontSize="20" Margin="5 0 0 0" Foreground="#7F8C8D"/>
                            </StackPanel>
                            <Button Content="手动清零" Style="{StaticResource ManualButtonStyle}" Width="100"
                                    Command="{Binding ClearJig2CountCommand}" Margin="0 10 0 0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 扫码记录表格卡片 -->
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="扫码记录（实时更新）" Style="{StaticResource SubTitleStyle}"/>
                        <DataGrid Grid.Row="1" Style="{StaticResource DataGridStyle}"
                                  ItemsSource="{Binding ScanRecords}"
                                  ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="时间" Binding="{Binding CreateTime, StringFormat=yyyy-MM-dd HH:mm:ss}" Width="160"/>
                                <DataGridTextColumn Header="治具编号" Binding="{Binding JigNo}" Width="80"/>
                                <DataGridTextColumn Header="扫码类型" Binding="{Binding ScanType}" Width="100"/>
                                <DataGridTextColumn Header="底板码" Binding="{Binding BottomCode}" Width="200"/>
                                <DataGridTextColumn Header="导向板码" Binding="{Binding TopCode}" Width="200"/>
                                <DataGridTextColumn Header="主板码" Binding="{Binding SPCode}" Width="140"/>
                                <DataGridTemplateColumn Header="扫码结果" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Result, Converter={StaticResource ResultToTextConverter}}"
                                                       Style="{StaticResource StatusLabelStyle}"
                                                       Background="{Binding Result, Converter={StaticResource StatusToColorConverter}}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="备注" Binding="{Binding Remark}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <!-- 右侧：机械臂状态 + 运行日志 -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 机械臂状态卡片 -->
                <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0 0 0 15">
                    <StackPanel>
                        <TextBlock Text="机械臂状态" Style="{StaticResource SubTitleStyle}" Margin="0 0 0 5"/>
                        <TextBlock Text="{Binding RobotStatus}" Style="{StaticResource StatusLabelStyle}"
                                   Background="{Binding RobotStatus, Converter={StaticResource StatusToColorConverter}}"
                                   Margin="0 0 0 8"/>
                        <TextBlock Text="当前扫码位：" FontWeight="SemiBold" Margin="0 5 0 0"/>
                        <TextBlock Text="{Binding RobotScanPosition}" Margin="0 2 0 5"/>
                        <TextBlock Text="最新报站结果：" FontWeight="SemiBold" Margin="0 5 0 0"/>
                        <TextBlock Text="{Binding RobotReportResult}" Margin="0 2 0 0"/>
                    </StackPanel>
                </Border>

                <!-- 运行日志卡片 -->
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="设备运行日志" Style="{StaticResource SubTitleStyle}" Margin="0 0 0 10"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <TextBlock Text="{Binding RunLog}" FontFamily="Consolas" FontSize="12"
                                       TextWrapping="Wrap" Padding="5"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- 4. 手动操作区（美化版） -->
        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="0 15 0 15">
            <StackPanel>
                <TextBlock Text="手动扫码（测试）" Style="{StaticResource SubTitleStyle}" Margin="0 0 0 10"/>
                <WrapPanel Orientation="Horizontal"  HorizontalAlignment="Left">
                    <Button Content="左下扫码" Style="{StaticResource ManualButtonStyle}"
                            Command="{Binding ManualTriggerLeftDownScanCommand}" Margin="2"/>
                    <Button Content="左上扫码" Style="{StaticResource ManualButtonStyle}"
                            Command="{Binding ManualTriggerLeftUpScanCommand}" Margin="2"/>
                    <Button Content="右上扫码" Style="{StaticResource ManualButtonStyle}"
                            Command="{Binding ManualTriggerRightUpScanCommand}" Margin="2"/>
                    <Button Content="右下扫码" Style="{StaticResource ManualButtonStyle}"
                            Command="{Binding ManualTriggerRightDownScanCommand}" Margin="2"/>
                    <Button Content="机械臂扫码" Style="{StaticResource ManualButtonStyle}"
                            Command="{Binding ManualTriggerRobotScanCommand}" Margin="2"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- 5. 硬件连接状态区 -->
        <Border Grid.Row="4" Style="{StaticResource CardStyle}" Background="#F8F9FA" Margin="0 0 0 0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="硬件连接状态（实时监控）" Style="{StaticResource SubTitleStyle}" Margin="0 0 0 10"/>
                <Grid Grid.Row="1" Margin="0 5 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="欧姆龙PLC" FontSize="12" Margin="0 0 0 5" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding IsPlcConnected, Converter={StaticResource BoolToTextConverter}}" 
                                   Style="{StaticResource HardwareStatusLabelStyle}"
                                   Background="{Binding IsPlcConnected, Converter={StaticResource StatusToColorConverter}}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="左上扫码枪" FontSize="12" Margin="0 0 0 5" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding IsLeftUpScannerConnected, Converter={StaticResource BoolToTextConverter}}" 
                                   Style="{StaticResource HardwareStatusLabelStyle}"
                                   Background="{Binding IsLeftUpScannerConnected, Converter={StaticResource StatusToColorConverter}}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="左下扫码枪" FontSize="12" Margin="0 0 0 5" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding IsLeftDownScannerConnected, Converter={StaticResource BoolToTextConverter}}" 
                                   Style="{StaticResource HardwareStatusLabelStyle}"
                                   Background="{Binding IsLeftDownScannerConnected, Converter={StaticResource StatusToColorConverter}}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                        <TextBlock Text="右上扫码枪" FontSize="12" Margin="0 0 0 5" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding IsRightUpScannerConnected, Converter={StaticResource BoolToTextConverter}}" 
                                   Style="{StaticResource HardwareStatusLabelStyle}"
                                   Background="{Binding IsRightUpScannerConnected, Converter={StaticResource StatusToColorConverter}}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                        <TextBlock Text="右下扫码枪" FontSize="12" Margin="0 0 0 5" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding IsRightDownScannerConnected, Converter={StaticResource BoolToTextConverter}}" 
                                   Style="{StaticResource HardwareStatusLabelStyle}"
                                   Background="{Binding IsRightDownScannerConnected, Converter={StaticResource StatusToColorConverter}}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="5" HorizontalAlignment="Center">
                        <TextBlock Text="机械臂扫码枪" FontSize="12" Margin="0 0 0 5" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding IsSPScannerConnected, Converter={StaticResource BoolToTextConverter}}" 
                                   Style="{StaticResource HardwareStatusLabelStyle}"
                                   Background="{Binding IsSPScannerConnected, Converter={StaticResource StatusToColorConverter}}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="6" HorizontalAlignment="Center">
                        <TextBlock Text="EPSON机械臂" FontSize="12" Margin="0 0 0 5" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding IsRobotConnected, Converter={StaticResource BoolToTextConverter}}" 
                                   Style="{StaticResource HardwareStatusLabelStyle}"
                                   Background="{Binding IsRobotConnected, Converter={StaticResource StatusToColorConverter}}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>